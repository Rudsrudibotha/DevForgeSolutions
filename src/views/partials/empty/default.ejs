<%# Reusable empty state. Args:
  - icon: optional SVG path d-attribute (defaults to inbox)
  - title: bold title text
  - desc: secondary description
  - action: optional { label, href, csrf } object
  - colspan: optional, when used inside a <tr>
%>
<% var ic = (typeof icon !== 'undefined' && icon) ? icon : 'M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4'; %>
<% if (typeof colspan !== 'undefined' && colspan) { %>
  <tr><td colspan="<%= colspan %>">
    <div class="empty-state">
      <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= ic %>"/></svg>
      <% if (typeof title !== 'undefined' && title) { %><p class="empty-state-title"><%= title %></p><% } %>
      <% if (typeof desc !== 'undefined' && desc) { %><p class="empty-state-desc"><%= desc %></p><% } %>
      <% if (typeof action !== 'undefined' && action && action.href) { %>
        <a href="<%= action.href %>" class="btn-primary btn-sm mt-3 inline-flex"><%= action.label || 'Take action' %></a>
      <% } %>
    </div>
  </td></tr>
<% } else { %>
  <div class="empty-state">
    <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= ic %>"/></svg>
    <% if (typeof title !== 'undefined' && title) { %><p class="empty-state-title"><%= title %></p><% } %>
    <% if (typeof desc !== 'undefined' && desc) { %><p class="empty-state-desc"><%= desc %></p><% } %>
    <% if (typeof action !== 'undefined' && action && action.href) { %>
      <a href="<%= action.href %>" class="btn-primary btn-sm mt-3 inline-flex"><%= action.label || 'Take action' %></a>
    <% } %>
  </div>
<% } %>
