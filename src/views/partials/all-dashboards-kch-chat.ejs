<% layout = 'layouts/app' %>
<% sidebar = typeof sidebarOverride !== 'undefined' ? sidebarOverride : 'school' %>

<div class="container-page">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="text-2xl font-semibold mb-1">Kinder Care Hub</h1>
      <p class="text-muted text-sm">Tenant-safe messaging, AI assistant, and Report a Fault.</p>
    </div>
    <% if (typeof showAi !== 'undefined' && showAi) { %>
      <span class="badge-brand" id="kchAiBadge">AI</span>
    <% } %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <!-- Conversation list -->
    <div class="lg:col-span-4 card">
      <div class="card-body p-0">
        <div class="p-3 border-b flex items-center gap-2">
          <input type="text" id="kchSearchInput" placeholder="Search conversations" class="input flex-1" />
          <button id="kchNewConversation" class="btn-secondary btn-icon" title="New conversation">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          </button>
        </div>
        <ul id="kchConversationList" class="divide-y" role="listbox" aria-label="Conversations"></ul>
        <div id="kchConversationEmpty" class="hidden p-6 text-center text-muted text-sm">No conversations yet.</div>
      </div>
    </div>

    <!-- Message panel + AI/Fault -->
    <div class="lg:col-span-5 card">
      <div class="card-body p-0 flex flex-col" style="min-height: 60vh;">
        <div class="p-3 border-b flex items-center justify-between">
          <div>
            <p class="text-sm font-semibold" id="kchConvTitle">Select a conversation</p>
            <p class="text-xs text-muted" id="kchConvSubtitle"></p>
          </div>
          <div class="flex items-center gap-2">
            <span id="kchUnreadPill" class="badge-brand hidden">0</span>
            <span id="kchConvType" class="badge"></span>
          </div>
        </div>
        <div id="kchMessageList" class="flex-1 overflow-y-auto p-3 space-y-2" style="max-height: 60vh;"></div>
        <div class="p-3 border-t">
          <div id="kchAttachmentPreview" class="hidden mb-2 text-xs text-muted">Image attached: <span id="kchAttachmentName"></span> <button id="kchRemoveAttachment" class="text-brand-600 hover:underline">remove</button></div>
          <form id="kchMessageForm" class="flex items-center gap-2">
            <input type="hidden" id="kchAttachmentId" />
            <label class="btn-secondary btn-icon cursor-pointer" title="Attach image" id="kchAttachLabel">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
              <input type="file" id="kchImageFile" accept="image/jpeg,image/png,image/webp" class="hidden" />
            </label>
            <input type="text" id="kchMessageInput" placeholder="Type a message..." class="input flex-1" maxlength="5000" />
            <button type="submit" id="kchSendBtn" class="btn-primary">Send</button>
          </form>
        </div>
      </div>
    </div>

    <!-- AI assistant / Fault report (DevForge + School only) -->
    <% if (typeof showAi !== 'undefined' && showAi) { %>
    <div class="lg:col-span-3 card">
      <div class="card-body p-0 flex flex-col" style="min-height: 60vh;">
        <div class="p-3 border-b flex items-center gap-2">
          <span class="badge-brand">AI</span>
          <p class="text-sm font-semibold flex-1">Kinder Care Assistant</p>
        </div>
        <div id="kchAiLog" class="flex-1 overflow-y-auto p-3 space-y-2 text-sm" style="max-height: 50vh;"></div>
        <div class="p-3 border-t">
          <form id="kchAiForm" class="flex items-center gap-2">
            <input type="text" id="kchAiInput" placeholder="Ask the assistant..." class="input flex-1" maxlength="2000" />
            <button type="submit" class="btn-primary">Ask</button>
          </form>
          <button id="kchFaultBtn" class="btn-secondary w-full mt-2">Report a Fault</button>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>

<!-- New conversation modal -->
<div id="kchNewConvModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
  <div class="card w-full max-w-md">
    <div class="card-body">
      <h2 class="text-lg font-semibold mb-3">New conversation</h2>
      <form id="kchNewConvForm" class="space-y-3">
        <div>
          <label class="label">Conversation type</label>
          <select id="kchNewConvType" class="input">
            <% if (typeof portal !== 'undefined' && portal === 'devforge') { %>
              <option value="DevForgeToSchool">DevForge → School</option>
              <option value="DevForgeToParent">DevForge → Parent</option>
            <% } else if (typeof portal !== 'undefined' && portal === 'sms') { %>
              <option value="SchoolInternal">School internal</option>
              <option value="SchoolToParent">School → Parent</option>
              <option value="SchoolToDevForge">School → DevForge support</option>
            <% } else { %>
              <option value="ParentToSchool">Parent → School</option>
            <% } %>
          </select>
        </div>
        <div>
          <label class="label">Recipient user IDs (comma-separated)</label>
          <input type="text" id="kchNewConvRecipients" class="input" placeholder="e.g. 12, 34" />
        </div>
        <div class="flex justify-end gap-2">
          <button type="button" id="kchNewConvCancel" class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-primary">Start</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Report a fault modal -->
<div id="kchFaultModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
  <div class="card w-full max-w-md">
    <div class="card-body">
      <h2 class="text-lg font-semibold mb-3">Report a Fault</h2>
      <form id="kchFaultForm" class="space-y-3">
        <div><label class="label">Screen / page</label><input type="text" id="kchFaultScreen" class="input" placeholder="e.g. /sms/students" /></div>
        <div><label class="label">Description</label><textarea id="kchFaultDescription" class="input" rows="4" required></textarea></div>
        <div>
          <label class="label">Priority</label>
          <select id="kchFaultPriority" class="input">
            <option value="Low">Low</option>
            <option value="Normal" selected>Normal</option>
            <option value="High">High</option>
            <option value="Urgent">Urgent</option>
          </select>
        </div>
        <div class="flex justify-end gap-2">
          <button type="button" id="kchFaultCancel" class="btn-secondary">Cancel</button>
          <button type="submit" class="btn-primary">Submit</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/kch-chat.js" defer></script>
