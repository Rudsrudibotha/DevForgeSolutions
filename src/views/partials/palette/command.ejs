<%# Command palette. Mounts once per page. Triggered by Ctrl/Cmd+K or /. %>
<div x-data="kchPaletteComponent()"
     x-cloak
     @keydown.window.escape="if (open) close()">
  <div x-show="open" x-transition.opacity class="modal-backdrop" @click.self="close()" style="display:none">
    <div class="modal-panel" style="align-items: flex-start; padding-top: 12vh">
      <div class="modal-content max-w-xl w-full" role="dialog" aria-modal="true" aria-label="Command palette" @click.stop>
        <div class="flex items-center gap-2 p-3 border-b" style="border-color: rgb(var(--color-border))">
          <svg class="h-4 w-4 text-muted shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
          <input id="kch-palette-input"
                 x-model="query"
                 @input="active = 0"
                 type="search"
                 placeholder="Search for a page or action..."
                 class="flex-1 bg-transparent outline-none text-sm"
                 autocomplete="off" />
          <kbd class="kbd text-xs">Esc</kbd>
        </div>
        <div class="max-h-96 overflow-auto py-2">
          <template x-for="group in groups" :key="group.name">
            <div class="px-2 py-1">
              <p class="text-xs uppercase tracking-wider text-muted px-2 py-1" x-text="group.name"></p>
              <template x-for="(it, i) in group.items" :key="it.href + i">
                <button type="button"
                        class="kch-palette-item w-full text-left flex items-center justify-between px-2 py-1.5 rounded hover:bg-slate-100 dark:hover:bg-slate-800"
                        :class="(group.startIndex + i) === active ? 'active' : ''"
                        @click="select(it)"
                        @mouseenter="active = group.startIndex + i">
                  <span class="text-sm truncate" x-text="it.label"></span>
                  <span class="text-xs text-muted truncate ml-2" x-text="it.href && it.href.indexOf('action:') === 0 ? 'action' : it.href"></span>
                </button>
              </template>
            </div>
          </template>
          <div x-show="filtered.length === 0" class="empty-state">
            <p class="empty-state-desc">No matches</p>
          </div>
        </div>
        <div class="border-t p-2 flex items-center gap-3 text-xs text-muted" style="border-color: rgb(var(--color-border))">
          <span class="flex items-center gap-1"><kbd class="kbd">&uarr;</kbd><kbd class="kbd">&darr;</kbd> navigate</span>
          <span class="flex items-center gap-1"><kbd class="kbd">&crarr;</kbd> select</span>
          <span class="flex items-center gap-1 ml-auto"><kbd class="kbd">Ctrl</kbd>+<kbd class="kbd">K</kbd> open</span>
        </div>
      </div>
    </div>
  </div>
</div>
