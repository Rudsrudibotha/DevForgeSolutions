<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Access denied</title>
  <link rel="stylesheet" href="/styles/app.css" />
</head>
<body class="min-h-screen flex items-center justify-center p-4">
  <div class="card max-w-md w-full p-8 text-center">
    <div class="mx-auto h-12 w-12 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mb-4">
      <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
      </svg>
    </div>
    <h1 class="text-xl font-semibold">Access denied</h1>
    <p class="text-muted mt-2 text-sm"><%= typeof message !== 'undefined' && message ? message : 'You do not have access to this area.' %></p>
    <div class="mt-6 flex justify-center gap-2">
      <a href="/" class="btn-secondary btn-sm">Go home</a>
      <a href="/login" class="btn-primary btn-sm">Sign in</a>
    </div>
  </div>
</body>
</html>
