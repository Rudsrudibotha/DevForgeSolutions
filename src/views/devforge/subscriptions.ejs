<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="mb-4">
    <h1 class="text-2xl font-semibold">Subscription management</h1>
    <p class="text-muted text-sm">Manage plans, tenant subscriptions, feature overrides, and usage.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card">
      <div class="card-body">
        <h2 class="text-lg font-semibold mb-2">Plans</h2>
        <ul id="plansList" class="text-sm space-y-2"></ul>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <h2 class="text-lg font-semibold mb-2">Tenants</h2>
        <ul id="tenantsList" class="text-sm space-y-2"></ul>
      </div>
    </div>
    <div class="card">
      <div class="card-body">
        <h2 class="text-lg font-semibold mb-2">Selected tenant features</h2>
        <select id="tenantSelect" class="input mb-2"></select>
        <ul id="featuresList" class="text-sm space-y-1 max-h-[60vh] overflow-y-auto"></ul>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const csrf = (document.querySelector('meta[name="csrf-token"]') || {}).content || '';
    const api = (path, options) => fetch(path, { credentials: 'same-origin', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf }, ...options }).then(r => r.json());

    function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])); }

    async function loadPlans() {
      const data = await api('/api/devforge-subscriptions/plans');
      const list = document.getElementById('plansList');
      list.innerHTML = (data.plans || []).map(p => '<li class="p-2 border rounded"><p class="font-semibold">' + escapeHtml(p.PlanName) + ' (' + escapeHtml(p.PlanCode) + ')</p><p class="text-xs text-muted">' + (p.features || []).filter(f => f.IsEnabled).length + ' features enabled</p></li>').join('');
    }

    async function loadTenants() {
      const data = await api('/api/devforge-subscriptions/tenants');
      const list = document.getElementById('tenantsList');
      const sel = document.getElementById('tenantSelect');
      list.innerHTML = (data.items || []).map(t => '<li class="p-2 border rounded"><p class="font-semibold">' + escapeHtml(t.TenantName) + '</p><p class="text-xs text-muted">' + escapeHtml(t.PlanName) + ' &middot; ' + escapeHtml(t.Status) + '</p><button class="btn-secondary btn-sm mt-1" data-action="suspend" data-id="' + t.TenantId + '">Suspend</button> <button class="btn-secondary btn-sm mt-1" data-action="reactivate" data-id="' + t.TenantId + '">Reactivate</button></li>').join('');
      sel.innerHTML = '<option value="">Select a tenant</option>' + (data.items || []).map(t => '<option value="' + t.TenantId + '">' + escapeHtml(t.TenantName) + '</option>').join('');
      list.addEventListener('click', async (e) => {
        const btn = e.target.closest('button[data-action]');
        if (!btn) return;
        const id = btn.getAttribute('data-id');
        const action = btn.getAttribute('data-action');
        if (action === 'suspend') await api('/api/devforge-subscriptions/tenants/' + id + '/suspend', { method: 'POST', body: '{}' });
        if (action === 'reactivate') await api('/api/devforge-subscriptions/tenants/' + id + '/reactivate', { method: 'POST', body: '{}' });
        loadTenants();
      });
      sel.addEventListener('change', () => {
        const id = sel.value;
        if (id) loadFeatures(id);
      });
    }

    async function loadFeatures(tenantId) {
      const data = await api('/api/devforge-subscriptions/tenants/' + tenantId + '/features');
      const list = document.getElementById('featuresList');
      list.innerHTML = (data.features || []).map(f => '<li class="p-2 border rounded"><p class="font-semibold">' + escapeHtml(f.FeatureName) + ' <span class="text-xs text-muted">' + escapeHtml(f.FeatureKey) + '</span></p><p class="text-xs">' + (f.IsAllowed ? 'Allowed' : 'Blocked') + ' &middot; ' + escapeHtml(f.Reason || '') + '</p><div class="mt-1 flex gap-1"><button class="btn-secondary btn-sm" data-override="1" data-feature="' + f.SaaSFeatureId + '">Enable</button> <button class="btn-secondary btn-sm" data-override="0" data-feature="' + f.SaaSFeatureId + '">Disable</button></div></li>').join('');
      list.addEventListener('click', async (e) => {
        const btn = e.target.closest('button[data-override]');
        if (!btn) return;
        const featureId = btn.getAttribute('data-feature');
        const enabled = btn.getAttribute('data-override') === '1';
        await api('/api/devforge-subscriptions/tenants/' + tenantId + '/overrides', { method: 'POST', body: JSON.stringify({ saasFeatureId: Number(featureId), isEnabled: enabled, reason: 'Manual override from admin UI' }) });
        loadFeatures(tenantId);
      });
    }

    document.addEventListener('DOMContentLoaded', () => { loadPlans(); loadTenants(); });
  })();
</script>
