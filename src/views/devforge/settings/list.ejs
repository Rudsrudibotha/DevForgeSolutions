<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Settings &amp; observability</h1>
      <p class="text-muted text-sm">Platform info, environment, kill switches, and the most recent state-changing events.</p>
    </div>
    <span class="badge-warning">All views audited</span>
  </div>

  <% if (health) { %>
    <div class="card mb-4">
      <div class="card-body py-3 flex flex-col sm:flex-row sm:items-center gap-3">
        <span class="badge-<%= health.status === 'healthy' ? 'success' : 'error' %>">
          <%= health.status === 'healthy' ? 'Healthy' : 'Degraded' %>
        </span>
        <div>
          <p class="text-sm font-medium"><%= health.database.connected ? 'Database connected' : 'Database disconnected' %></p>
          <% if (health.database.lastError) { %>
            <p class="text-xs text-muted"><%= health.database.lastError %></p>
          <% } %>
        </div>
        <p class="text-xs text-muted sm:ml-auto"><%= new Date(health.timestamp).toLocaleString('en-ZA') %></p>
      </div>
    </div>
  <% } %>

  <% if (platform) { %>
    <div class="card mb-4">
      <div class="card-body">
        <h2 class="text-sm font-semibold mb-3">Platform</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 text-sm">
          <div>
            <p class="text-muted text-xs">Version</p>
            <p class="font-mono"><%= platform.version %></p>
          </div>
          <div>
            <p class="text-muted text-xs">Node</p>
            <p class="font-mono"><%= platform.node %></p>
          </div>
          <div>
            <p class="text-muted text-xs">Environment</p>
            <p><%= platform.env %></p>
          </div>
          <div>
            <p class="text-muted text-xs">Uptime</p>
            <p><%= platform.uptimeHuman %></p>
          </div>
          <div>
            <p class="text-muted text-xs">PID</p>
            <p class="font-mono"><%= platform.pid %></p>
          </div>
          <div>
            <p class="text-muted text-xs">Deps</p>
            <p><%= platform.deps %></p>
          </div>
          <div class="col-span-2">
            <p class="text-muted text-xs">Started</p>
            <p class="font-mono text-xs"><%= platform.startedAt %></p>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <% if (settings && settings.length > 0) { %>
    <div class="card mb-4">
      <div class="card-body">
        <h2 class="text-sm font-semibold mb-3">Platform toggles</h2>
        <p class="text-xs text-muted mb-3">Toggling these affects every school. All changes are audit-logged.</p>
        <div class="space-y-3">
          <% settings.forEach(function(s) { %>
            <% if (s._error) { %>
              <div class="alert alert-error"><%= s._error %></div>
            <% } else { %>
              <div class="flex flex-col sm:flex-row sm:items-center gap-2 py-2 border-b border-border last:border-0">
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-sm"><%= s.SettingKey %></p>
                  <% if (s.Description) { %>
                    <p class="text-xs text-muted"><%= s.Description %></p>
                  <% } %>
                  <% if (s.UpdatedAt) { %>
                    <p class="text-xs text-muted mt-0.5">Last changed: <%= new Date(s.UpdatedAt).toLocaleString('en-ZA') %><% if (s.UpdatedBy) { %> by <%= s.UpdatedBy %><% } %></p>
                  <% } %>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <select data-key="<%= s.SettingKey %>" class="select w-32 platform-setting-select" <%= !csrfToken ? '' : 'data-csrf="' + csrfToken + '"' %>>
                    <% var isOn = s.SettingValue === 'on' || s.SettingValue === 'true' || s.SettingValue === '1'; %>
                    <option value="on"  <%= isOn ? 'selected' : '' %>>on</option>
                    <option value="off" <%= !isOn ? 'selected' : '' %>>off</option>
                  </select>
                  <span class="status-indicator text-xs text-muted"></span>
                </div>
              </div>
            <% } %>
          <% }) %>
        </div>
      </div>
    </div>
  <% } %>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="text-sm font-semibold mb-3">Environment</h2>
      <% if (env && env.length > 0) { %>
        <div class="table-wrap">
          <table class="table">
            <thead><tr><th>Key</th><th>Value</th></tr></thead>
            <tbody>
              <% env.forEach(function(e) { %>
                <tr>
                  <td class="font-mono text-xs"><%= e.key %></td>
                  <td class="font-mono text-xs <%= e.redacted ? 'text-muted' : '' %>"><%= e.value %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-sm text-muted">No environment variables configured.</p>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h2 class="text-sm font-semibold mb-3">Recent state-changing events</h2>
      <p class="text-xs text-muted mb-3">The 10 most recent writes across the platform. <a href="/devforge/audit" class="text-brand hover:underline">View full audit log →</a></p>
      <% if (recentErrors && recentErrors.length > 0) { %>
        <div class="table-wrap">
          <table class="table">
            <thead><tr><th>When</th><th>Action</th><th>Resource</th><th>Actor</th><th>School</th></tr></thead>
            <tbody>
              <% recentErrors.forEach(function(e) { %>
                <tr>
                  <td class="text-xs text-muted whitespace-nowrap"><%= new Date(e.OccurredAt).toLocaleString('en-ZA', { dateStyle: 'short', timeStyle: 'short' }) %></td>
                  <td><span class="badge-neutral"><%= e.Action %></span></td>
                  <td class="text-sm"><%= e.ResourceType %><% if (e.ResourceID) { %> #<%= e.ResourceID %><% } %></td>
                  <td class="text-xs text-muted"><%= e.ActorEmail || '—' %></td>
                  <td class="text-xs text-muted">#<%= e.SchoolID || '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-sm text-muted">No recent events.</p>
      <% } %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('change', async function (ev) {
    const sel = ev.target.closest('.platform-setting-select');
    if (!sel) return;
    const key = sel.dataset.key;
    const value = sel.value;
    const indicator = sel.parentElement.querySelector('.status-indicator');
    const csrf = sel.dataset.csrf;
    indicator.textContent = 'saving…';
    indicator.classList.remove('text-success', 'text-error');
    try {
      const res = await fetch('/devforge/settings/' + encodeURIComponent(key), {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrf || '' },
        body: 'value=' + encodeURIComponent(value)
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      indicator.textContent = 'saved';
      indicator.classList.add('text-success');
      setTimeout(() => { indicator.textContent = ''; indicator.classList.remove('text-success'); }, 2000);
    } catch (err) {
      indicator.textContent = 'failed: ' + err.message;
      indicator.classList.add('text-error');
    }
  });
</script>
