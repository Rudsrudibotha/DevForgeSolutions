<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Reported faults</h1>
      <p class="text-muted text-sm">Issues reported by schools from their dashboards and the Kinder Care Hub chat.</p>
    </div>
  </div>

  <form method="get" action="/devforge/faults"
        hx-get="/devforge/faults/partials/table"
        hx-trigger="change from:select"
        hx-target="#faults-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body py-3 flex flex-wrap items-center gap-2">
      <label class="text-sm text-muted" for="statusFilter">Status</label>
      <select id="statusFilter" name="status" class="select max-w-[12rem]">
        <option value="">All statuses</option>
        <% statuses.forEach(function(s) { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
  </form>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>School</th>
          <th>Where</th>
          <th>Reported by</th>
          <th>Status</th>
          <th>Reported</th>
          <th class="text-right">Action</th>
        </tr>
      </thead>
      <tbody id="faults-table">
        <%- include('partials/table', { rows, statuses, filters, layout: false }) %>
      </tbody>
    </table>
  </div>
</div>
