<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', { title: 'No payments found', desc: 'Try widening the date range or clearing the filters.', colspan: 8 }) %>
<% } else { %>
  <% rows.forEach(function(t) { %>
    <tr>
      <td class="text-sm text-muted whitespace-nowrap">
        <%= new Date(t.TransactionDate).toLocaleDateString('en-ZA') %>
      </td>
      <td class="text-sm">
        <span class="badge-neutral"><%= t.SchoolName %></span>
      </td>
      <td class="text-sm font-medium">
        <%= t.ReceiptNumber || '—' %>
      </td>
      <td class="text-sm text-muted"><%= t.PaymentMethod || '—' %></td>
      <td>
        <p class="text-sm font-medium"><%= t.PayeeName || '—' %></p>
        <% if (t.FamilyName) { %>
          <p class="text-xs text-muted"><%= t.FamilyName %><% if (t.StudentName) { %> · <%= t.StudentName %><% } %></p>
        <% } %>
      </td>
      <td class="text-sm text-muted">
        <% if (t.InvoiceNumber) { %>
          <a href="#" class="hover:underline"><%= t.InvoiceNumber %></a>
        <% } else { %>—<% } %>
      </td>
      <td class="text-right font-medium whitespace-nowrap">R <%= formatMoney(t.Amount) %></td>
      <td>
        <% if (t.AllocationStatus === 'Allocated') { %>
          <span class="badge-success">Allocated</span>
        <% } else if (t.AllocationStatus === 'Unallocated') { %>
          <span class="badge-warning">Unallocated</span>
        <% } else if (t.AllocationStatus === 'PendingPayment') { %>
          <span class="badge-brand">Pending parent</span>
        <% } else { %>
          <span class="badge-neutral"><%= t.AllocationStatus %></span>
        <% } %>
      </td>
    </tr>
  <% }) %>
<% } %>
