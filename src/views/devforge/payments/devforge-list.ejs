<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Payments</h1>
      <p class="text-muted text-sm">Cross-school payment ledger — every transaction across every school</p>
    </div>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
    <div class="kpi-card">
      <p class="kpi-label">Collected (30d)</p>
      <p class="kpi-value text-lg">R <%= formatMoney(kpis.CollectedLast30Days || 0) %></p>
      <p class="kpi-help">Allocated in last 30 days</p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Unallocated</p>
      <p class="kpi-value text-lg">R <%= formatMoney(kpis.UnallocatedTotal || 0) %></p>
      <p class="kpi-help"><%= kpis.UnallocatedCount || 0 %> awaiting allocation</p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Pending parent</p>
      <p class="kpi-value text-lg">R <%= formatMoney(kpis.PendingParentTotal || 0) %></p>
      <p class="kpi-help">Awaiting school reconciliation</p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Filtered total</p>
      <p class="kpi-value text-lg">R <%= formatMoney(totalAmount) %></p>
      <p class="kpi-help"><%= total %> transaction<%= total === 1 ? '' : 's' %></p>
    </div>
  </div>

  <form method="get" action="/devforge/payments"
        hx-get="/devforge/payments/partials/table"
        hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select"
        hx-target="#payments-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body py-3 grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-6 gap-2">
      <div class="relative sm:col-span-2">
        <input type="search" name="q" value="<%= filters.search %>" placeholder="Search receipt, payee, ref..." class="input pl-9" />
        <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
      </div>
      <select name="schoolId" class="select">
        <option value="">All schools</option>
        <% schools.forEach(function(s) { %>
          <option value="<%= s.SchoolID %>" <%= String(filters.schoolId) === String(s.SchoolID) ? 'selected' : '' %>><%= s.SchoolName %></option>
        <% }) %>
      </select>
      <select name="allocationStatus" class="select">
        <option value="">All statuses</option>
        <option value="Allocated"      <%= filters.allocationStatus === 'Allocated' ? 'selected' : '' %>>Allocated</option>
        <option value="Unallocated"    <%= filters.allocationStatus === 'Unallocated' ? 'selected' : '' %>>Unallocated</option>
        <option value="PendingPayment" <%= filters.allocationStatus === 'PendingPayment' ? 'selected' : '' %>>Pending parent</option>
      </select>
      <select name="paymentMethod" class="select">
        <option value="">All methods</option>
        <% ['EFT', 'Cash', 'Card', 'Debit Order', 'Mobile'].forEach(function(m) { %>
          <option value="<%= m %>" <%= filters.paymentMethod === m ? 'selected' : '' %>><%= m %></option>
        <% }) %>
      </select>
      <div class="flex gap-1">
        <input type="date" name="from" value="<%= filters.from %>" class="input flex-1" title="From" />
        <input type="date" name="to"   value="<%= filters.to %>"   class="input flex-1" title="To" />
      </div>
    </div>
  </form>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>School</th>
          <th>Receipt</th>
          <th>Method</th>
          <th>Payee / Family</th>
          <th>Invoice</th>
          <th class="text-right">Amount</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="payments-table"
             hx-get="/devforge/payments/partials/table"
             hx-trigger="refresh-payments from:body"
             hx-swap="innerHTML">
        <tr class="htmx-indicator"><td colspan="8"><%- include('../../partials/empty/skeleton-table', { rows: 5, cols: 8, inline: true }) %></td></tr>
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, layout: false }) %>
      </tbody>
    </table>
  </div>

  <% if (hasMore) { %>
    <div class="text-center mt-4">
      <a href="?q=<%= encodeURIComponent(filters.search) %>&schoolId=<%= encodeURIComponent(filters.schoolId) %>&allocationStatus=<%= encodeURIComponent(filters.allocationStatus) %>&paymentMethod=<%= encodeURIComponent(filters.paymentMethod) %>&from=<%= encodeURIComponent(filters.from) %>&to=<%= encodeURIComponent(filters.to) %>&page=<%= page + 1 %>"
         class="btn-secondary">Load more</a>
    </div>
  <% } %>
</div>
