<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Schools</h1>
      <p class="text-muted text-sm"><%= total %> school<%= total === 1 ? '' : 's' %> across the platform</p>
    </div>
    <div class="flex items-center gap-2">
      <a href="/devforge/audit" class="btn-secondary btn-sm">View audit log</a>
      <a href="/devforge/schools/new" class="btn-primary btn-sm">Register school</a>
    </div>
  </div>

  <form method="get" action="/devforge/schools"
        hx-get="/devforge/schools/partials/table"
        hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select"
        hx-target="#schools-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body py-3 grid grid-cols-1 sm:grid-cols-4 gap-2">
      <div class="flex-1 relative sm:col-span-2">
        <input type="search" name="q" value="<%= filters.search %>" placeholder="Search by name, contact, or ID..." class="input pl-9" />
        <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
      </div>
      <select name="plan" class="select">
        <option value="">All plans</option>
        <% ['Standard', 'Pro', 'Pro+'].forEach(function(p) { %>
          <option value="<%= p %>" <%= filters.plan === p ? 'selected' : '' %>><%= p %></option>
        <% }) %>
      </select>
      <select name="status" class="select">
        <option value="">All statuses</option>
        <% ['Active', 'Suspended', 'Cancelled'].forEach(function(s) { %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
  </form>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>School</th>
          <th>Plan</th>
          <th>Status</th>
          <th>Contact</th>
          <th class="text-right">Users</th>
          <th class="text-right">Students</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="schools-table"
             hx-get="/devforge/schools/partials/table"
             hx-trigger="refresh-schools from:body"
             hx-swap="innerHTML">
        <tr class="htmx-indicator"><td colspan="7"><%- include('../../partials/empty/skeleton-table', { rows: 5, cols: 7, inline: true }) %></td></tr>
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, layout: false }) %>
      </tbody>
    </table>
  </div>
</div>
