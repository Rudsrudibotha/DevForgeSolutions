<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', { title: 'No audit events', desc: 'Try widening the date range or clearing the filters.', colspan: 6 }) %>
<% } else { %>
  <% rows.forEach(function(a) { %>
    <tr>
      <td class="text-xs text-muted whitespace-nowrap">
        <%= new Date(a.OccurredAt).toLocaleString('en-ZA', { dateStyle: 'short', timeStyle: 'short' }) %>
      </td>
      <td class="text-sm">
        <p class="font-medium"><%= a.ActorEmail || '—' %></p>
        <p class="text-xs text-muted"><%= a.ActorRole %><% if (a.ActorUsername) { %> · <%= a.ActorUsername %><% } %></p>
      </td>
      <td>
        <% if (a.Action === 'WRITE' || a.Action === 'CREATE' || a.Action === 'UPDATE' || a.Action === 'SUSPEND' || a.Action === 'ACTIVATE') { %>
          <span class="badge-warning"><%= a.Action %></span>
        <% } else if (a.Action === 'READ' || a.Action === 'EXPORT') { %>
          <span class="badge-neutral"><%= a.Action %></span>
        <% } else if (a.Action === 'LOGIN_FAIL') { %>
          <span class="badge-error"><%= a.Action %></span>
        <% } else if (a.Action === 'DELETE') { %>
          <span class="badge-error"><%= a.Action %></span>
        <% } else { %>
          <span class="badge-neutral"><%= a.Action %></span>
        <% } %>
      </td>
      <td class="text-sm">
        <p class="font-medium"><%= a.ResourceType || '—' %></p>
        <% if (a.ResourceID) { %><p class="text-xs text-muted">#<%= a.ResourceID %></p><% } %>
      </td>
      <td class="text-sm text-muted">
        <%= a.SchoolName || '—' %>
      </td>
      <td>
        <% if (a.PayloadParsed || a.PayloadRaw) { %>
          <details class="text-xs">
            <summary class="cursor-pointer text-muted hover:text-brand">show</summary>
            <% if (a.PayloadParsed) { %>
              <table class="mt-1 w-full">
                <% Object.keys(a.PayloadParsed).forEach(function(k) { %>
                  <tr>
                    <td class="text-muted pr-2 align-top"><%= k %></td>
                    <td class="font-mono text-xs break-all">
                      <% var v = a.PayloadParsed[k]; %>
                      <% if (v && typeof v === 'object') { %>
                        <code><%= JSON.stringify(v) %></code>
                      <% } else { %>
                        <%= v == null ? '—' : v %>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </table>
            <% } else { %>
              <pre class="mt-1 font-mono text-xs whitespace-pre-wrap"><%= a.PayloadRaw %></pre>
            <% } %>
          </details>
        <% } else { %>
          <span class="text-muted text-xs">—</span>
        <% } %>
      </td>
    </tr>
  <% }) %>
<% } %>
