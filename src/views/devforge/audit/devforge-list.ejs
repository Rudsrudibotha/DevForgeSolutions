<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Audit log</h1>
      <p class="text-muted text-sm">Every action taken on cross-school data is recorded here, including viewing this page.</p>
    </div>
    <span class="badge-warning">Read-only</span>
  </div>

  <form method="get" action="/devforge/audit"
        hx-get="/devforge/audit/partials/table"
        hx-trigger="keyup changed delay:250ms from:input[name=actorEmail], change from:select, change from:input[type=date]"
        hx-target="#audit-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body py-3 grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-6 gap-2">
      <div class="relative sm:col-span-2">
        <input type="search" name="actorEmail" value="<%= filters.actorEmail %>" placeholder="Filter by actor email..." class="input pl-9" />
        <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
      </div>
      <select name="schoolId" class="select">
        <option value="">All schools</option>
        <% schools.forEach(function(s) { %>
          <option value="<%= s.SchoolID %>" <%= String(filters.schoolId) === String(s.SchoolID) ? 'selected' : '' %>><%= s.SchoolName %></option>
        <% }) %>
      </select>
      <select name="action" class="select">
        <option value="">All actions</option>
        <% actions.forEach(function(a) { %>
          <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a %></option>
        <% }) %>
      </select>
      <select name="resourceType" class="select">
        <option value="">All resources</option>
        <% resourceTypes.forEach(function(r) { %>
          <option value="<%= r %>" <%= filters.resourceType === r ? 'selected' : '' %>><%= r %></option>
        <% }) %>
      </select>
      <div class="flex gap-1">
        <input type="date" name="from" value="<%= filters.from %>" class="input flex-1" title="From" />
        <input type="date" name="to"   value="<%= filters.to %>"   class="input flex-1" title="To" />
      </div>
    </div>
  </form>

  <p class="text-xs text-muted mb-2"><%= total %> event<%= total === 1 ? '' : 's' %> · page <%= page %></p>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>When</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Resource</th>
          <th>School</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="audit-table"
             hx-get="/devforge/audit/partials/table"
             hx-trigger="refresh-audit from:body"
             hx-swap="innerHTML">
        <tr class="htmx-indicator"><td colspan="6"><%- include('../../partials/empty/skeleton-table', { rows: 5, cols: 6, inline: true }) %></td></tr>
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, layout: false }) %>
      </tbody>
    </table>
  </div>

  <% if (hasMore) { %>
    <div class="text-center mt-4">
      <a href="?actorEmail=<%= encodeURIComponent(filters.actorEmail) %>&schoolId=<%= encodeURIComponent(filters.schoolId) %>&action=<%= encodeURIComponent(filters.action) %>&resourceType=<%= encodeURIComponent(filters.resourceType) %>&from=<%= encodeURIComponent(filters.from) %>&to=<%= encodeURIComponent(filters.to) %>&page=<%= page + 1 %>"
         class="btn-secondary">Load more</a>
    </div>
  <% } %>
</div>
