<% layout = 'layouts/app' %>
<% sidebar = 'devforge' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Users</h1>
      <p class="text-muted text-sm"><%= total %> user<%= total === 1 ? '' : 's' %> across the platform</p>
    </div>
  </div>

  <form method="get" action="/devforge/users"
        hx-get="/devforge/users/partials/table"
        hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select"
        hx-target="#users-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body py-3 grid grid-cols-1 sm:grid-cols-4 gap-2">
      <div class="flex-1 relative sm:col-span-2">
        <input type="search" name="q" value="<%= filters.search %>" placeholder="Search by username, email, or ID..." class="input pl-9" />
        <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
      </div>
      <select name="role" class="select">
        <option value="">All roles</option>
        <% ['admin', 'school', 'parent'].forEach(function(r) { %>
          <option value="<%= r %>" <%= filters.role === r ? 'selected' : '' %>><%= r %></option>
        <% }) %>
      </select>
      <select name="schoolId" class="select">
        <option value="">All schools</option>
        <% schools.forEach(function(s) { %>
          <option value="<%= s.SchoolID %>" <%= String(filters.schoolId) === String(s.SchoolID) ? 'selected' : '' %>><%= s.SchoolName %></option>
        <% }) %>
      </select>
      <select name="status" class="select sm:col-span-4 sm:w-32">
        <option value="">All statuses</option>
        <option value="active"   <%= filters.status === 'active'   ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
      </select>
    </div>
  </form>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>School</th>
          <th>Last login</th>
          <th>Created</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="users-table"
             hx-get="/devforge/users/partials/table"
             hx-trigger="refresh-users from:body"
             hx-swap="innerHTML">
        <tr class="htmx-indicator"><td colspan="7"><%- include('../../partials/empty/skeleton-table', { rows: 5, cols: 7, inline: true }) %></td></tr>
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, layout: false }) %>
      </tbody>
    </table>
  </div>
</div>
