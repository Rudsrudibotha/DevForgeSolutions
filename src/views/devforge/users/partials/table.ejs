<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', { title: 'No users found', desc: 'Try adjusting your search or filters.', colspan: 7 }) %>
<% } else { %>
  <% rows.forEach(function(u) { %>
    <tr>
      <td>
        <a href="/devforge/users/<%= u.UserID %>" class="font-medium hover:underline"><%= u.Username || '(no username)' %></a>
        <p class="text-xs text-muted"><%= u.Email %></p>
      </td>
      <td>
        <% if (u.Role === 'admin') { %><span class="badge-brand">admin</span>
        <% } else if (u.Role === 'school') { %><span class="badge-neutral">school</span>
        <% } else { %><span class="badge-neutral">parent</span><% } %>
      </td>
      <td class="text-sm text-muted"><%= u.SchoolName || '—' %></td>
      <td class="text-sm text-muted"><%= u.LastLoginDate ? formatDate(u.LastLoginDate) : 'Never' %></td>
      <td class="text-sm text-muted"><%= formatDate(u.CreatedDate) %></td>
      <td>
        <% if (u.IsActive) { %><span class="badge-success">Active</span>
        <% } else { %><span class="badge-neutral">Inactive</span><% } %>
      </td>
      <td class="text-right">
        <a href="/devforge/users/<%= u.UserID %>" class="btn-ghost btn-sm">View</a>
      </td>
    </tr>
  <% }) %>
<% } %>
