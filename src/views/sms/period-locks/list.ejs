<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Finance period locks</h1>
      <p class="text-muted text-sm">Lock financial periods to prevent late edits.</p>
    </div>
  </div>

  <form method="post" action="/sms/period-locks"
        hx-post="/sms/period-locks"
        hx-target="this"
        hx-swap="outerHTML"
        class="card mb-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="card-body space-y-4">
      <% if (errors && errors._form) { %>
        <div class="alert alert-error"><%= errors._form %></div>
      <% } %>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-3">
        <div class="form-field">
          <label class="label" for="lockType">Lock type</label>
          <select id="lockType" name="lockType" class="select">
            <% ['Month','Year','Custom'].forEach(function(t) { %>
              <option value="<%= t %>" <%= (form.lockType || 'Month') === t ? 'selected' : '' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label class="label" for="year">Year</label>
          <input id="year" name="year" type="number" min="2000" max="2100" class="input" value="<%= form.year || new Date().getFullYear() %>" />
        </div>
        <div class="form-field">
          <label class="label" for="month">Month</label>
          <input id="month" name="month" type="number" min="1" max="12" class="input" value="<%= form.month || (new Date().getMonth() + 1) %>" />
        </div>
        <div class="form-field">
          <label class="label" for="periodStart">Custom start</label>
          <input id="periodStart" name="periodStart" type="date" class="input" value="<%= form.periodStart || '' %>" />
        </div>
        <div class="form-field">
          <label class="label" for="periodEnd">Custom end</label>
          <input id="periodEnd" name="periodEnd" type="date" class="input" value="<%= form.periodEnd || '' %>" />
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-end">
        <div class="form-field">
          <label class="label label-required" for="reason">Reason</label>
          <input id="reason" name="reason" type="text" maxlength="500" required class="input" value="<%= form.reason || '' %>" />
        </div>
        <button type="submit" class="btn-primary">Lock period</button>
      </div>
    </div>
  </form>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Type</th>
              <th>Period</th>
              <th>Reason</th>
              <th>Locked at</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(list || []).length) { %>
              <tr><td colspan="6" class="text-center text-muted py-6">No period locks set.</td></tr>
            <% } else { %>
              <% list.forEach(function (p) { %>
                <tr>
                  <td><%= p.FinancePeriodLockID || p.financePeriodLockId %></td>
                  <td><%= p.LockType || '-' %></td>
                  <td><%= p.PeriodStart ? formatDate(p.PeriodStart) : '-' %> - <%= p.PeriodEnd ? formatDate(p.PeriodEnd) : '' %></td>
                  <td><%= p.Reason || '-' %></td>
                  <td><%= p.LockedAt ? new Date(p.LockedAt).toLocaleString('en-ZA') : '-' %></td>
                  <td class="text-right">
                    <button class="btn-secondary btn-sm" hx-put="/api/school-features/finance-period-locks/<%= p.FinancePeriodLockID %>/reopen" hx-vals='{"reason":"Reopened from school dashboard"}' hx-swap="none" hx-on::after-request="if(event.detail.successful) location.reload()" onclick="return confirm('Reopen this period? Existing invoices remain but new edits will be allowed.');">Reopen</button>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
