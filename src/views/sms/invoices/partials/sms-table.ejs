<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', {
    icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z',
    title: 'No invoices found',
    desc: (filters && (filters.search || filters.status || filters.overdueOnly)) ? 'Try clearing your filters.' : 'Generate your first invoice to bill families.',
    action: (filters && (filters.search || filters.status || filters.overdueOnly)) ? null : { label: 'Generate invoice', href: '/sms/invoices/new' },
    colspan: 8
  }) %>
<% } else { %>
  <% rows.forEach(function(inv) { %>
    <tr id="invoice-row-<%= inv.InvoiceID %>">
      <td>
        <a href="/sms/invoices/<%= inv.InvoiceID %>" class="font-medium hover:underline">#<%= inv.InvoiceNumber %></a>
        <% if (inv.PaymentCount > 0) { %><p class="text-xs text-muted"><%= inv.PaymentCount %> payment<%= inv.PaymentCount === 1 ? '' : 's' %></p><% } %>
      </td>
      <td>
        <a href="/sms/students/<%= inv.StudentID %>" class="text-sm hover:underline"><%= inv.StudentName %></a>
        <p class="text-xs text-muted"><%= inv.FamilyName %></p>
      </td>
      <td class="text-sm <%= inv.Status !== 'Paid' && inv.Status !== 'Cancelled' && inv.DueDate && new Date(inv.DueDate) < new Date() ? 'text-red-600 dark:text-red-400 font-medium' : 'text-muted' %>">
        <%= inv.DueDate ? new Date(inv.DueDate).toLocaleDateString('en-ZA') : '—' %>
      </td>
      <td class="text-right text-money">R <%= Number(inv.Amount).toFixed(2) %></td>
      <td class="text-right text-money">R <%= Number(inv.AmountPaid || 0).toFixed(2) %></td>
      <td class="text-right text-money">
        <% if (Number(inv.Outstanding) > 0) { %>
          <span class="text-red-600 dark:text-red-400 font-medium">R <%= Number(inv.Outstanding).toFixed(2) %></span>
        <% } else { %>
          <span class="text-emerald-600 dark:text-emerald-400">R 0.00</span>
        <% } %>
      </td>
      <td>
        <% if (inv.Status === 'Paid') { %><span class="badge-success">Paid</span>
        <% } else if (inv.Status === 'Overdue' || (inv.Status !== 'Paid' && inv.Status !== 'Cancelled' && inv.DueDate && new Date(inv.DueDate) < new Date())) { %><span class="badge-danger">Overdue</span>
        <% } else if (inv.Status === 'PendingPayment') { %><span class="badge-warning">Awaiting parent</span>
        <% } else if (inv.Status === 'Partial') { %><span class="badge-warning">Partial</span>
        <% } else if (inv.Status === 'Cancelled') { %><span class="badge-neutral">Cancelled</span>
        <% } else { %><span class="badge-neutral"><%= inv.Status %></span><% } %>
      </td>
      <td class="text-right">
        <a href="/sms/invoices/<%= inv.InvoiceID %>" class="btn-ghost btn-sm">View</a>
      </td>
    </tr>
  <% }) %>
<% } %>
