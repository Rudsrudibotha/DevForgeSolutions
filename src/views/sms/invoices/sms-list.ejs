<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Invoices</h1>
      <p class="text-muted text-sm"><%= total %> invoice<%= total === 1 ? '' : 's' %></p>
    </div>
    <a href="/sms/invoices/new" class="btn-primary">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Generate invoices
    </a>
  </div>

  <!-- KPI strip -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="kpi-card">
      <p class="kpi-label">Total outstanding</p>
      <p class="kpi-value text-money">R <%= (kpis.totalOutstanding || 0).toFixed(2) %></p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Overdue</p>
      <p class="kpi-value text-money text-red-600 dark:text-red-400">R <%= (kpis.totalOverdue || 0).toFixed(2) %></p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Invoice count</p>
      <p class="kpi-value"><%= kpis.count || 0 %></p>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" action="/sms/invoices"
        hx-get="/sms/invoices/partials/table"
        hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select, change from:input[type=date]"
        hx-target="#invoices-table"
        hx-swap="innerHTML"
        hx-push-url="true"
        class="card mb-4">
    <div class="card-body grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <div class="form-field">
        <label class="label">Search</label>
        <input type="search" name="q" value="<%= filters.search %>" placeholder="Invoice #, student, family..." class="input" />
      </div>
      <div class="form-field">
        <label class="label">Status</label>
        <select name="status" class="select">
          <option value="">All</option>
          <% ['Pending','Overdue','Partial','Paid','PendingPayment','Cancelled'].forEach(function(s) { %>
            <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-field">
        <label class="label">From</label>
        <input type="date" name="from" value="<%= filters.from %>" class="input" />
      </div>
      <div class="form-field">
        <label class="label">To</label>
        <input type="date" name="to" value="<%= filters.to %>" class="input" />
      </div>
      <div class="form-field sm:col-span-2 lg:col-span-4">
        <label class="flex items-center gap-2">
          <input type="checkbox" name="overdueOnly" value="1" <%= filters.overdueOnly ? 'checked' : '' %> class="checkbox" />
          <span class="text-sm">Show only overdue</span>
        </label>
      </div>
    </div>
    <div class="card-footer">
      <button type="button" class="btn-ghost btn-sm" onclick="window.location='/sms/invoices'">Reset filters</button>
    </div>
  </form>

  <!-- Table -->
  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Invoice #</th>
          <th>Student / Family</th>
          <th>Due</th>
          <th class="text-right">Amount</th>
          <th class="text-right">Paid</th>
          <th class="text-right">Outstanding</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="invoices-table"
             hx-get="/sms/invoices/partials/table"
             hx-trigger="refresh-invoices from:body"
             hx-swap="innerHTML">
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, kpis, layout: false }) %>
      </tbody>
    </table>
  </div>

  <% if (total > pageSize) { %>
    <div class="mt-4 flex items-center justify-between text-sm">
      <p class="text-muted">Page <%= page %> of <%= Math.ceil(total / pageSize) %></p>
      <div class="flex gap-2">
        <% var qs = Object.entries(filters).filter(function(e){ var k=e[0],v=e[1]; if(['status','studentId','familyId'].indexOf(k)>=0) return false; return v; }).map(function(e){ return e[0]+'='+encodeURIComponent(e[1]); }).join('&'); %>
        <% if (page > 1) { %>
          <a href="/sms/invoices?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/invoices/partials/table?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#invoices-table" hx-swap="innerHTML" hx-push-url="true">Previous</a>
        <% } %>
        <% if (hasMore) { %>
          <a href="/sms/invoices?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/invoices/partials/table?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#invoices-table" hx-swap="innerHTML" hx-push-url="true">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
