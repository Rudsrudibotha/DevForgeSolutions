<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page" x-data="attendanceSheet()">
  <nav class="mb-4 text-sm">
    <a href="/sms/attendance" class="text-muted hover:underline">Attendance</a>
    <span class="text-muted mx-1">/</span>
    <span><%= klass.ClassName %></span>
  </nav>

  <div class="card mb-4">
    <div class="card-body flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold">Take attendance</h1>
        <p class="text-muted text-sm">
          <%= klass.ClassName %><% if (klass.Grade) { %> &middot; Grade <%= klass.Grade %><% } %>
          &middot; <%= new Date(date).toLocaleDateString('en-ZA', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %>
        </p>
      </div>
      <form method="get" action="/sms/attendance/<%= klass.ClassID %>" class="flex items-end gap-2">
        <div class="form-field">
          <label class="label">Date</label>
          <input type="date" name="date" value="<%= date %>" class="input" onchange="this.form.submit()" />
        </div>
        <a href="/sms/attendance/<%= klass.ClassID %>/history" class="btn-secondary btn-sm">History</a>
      </form>
    </div>
  </div>

  <% if (!sheet.rows || sheet.rows.length === 0) { %>
    <div class="card">
      <div class="card-body empty-state">
        <p class="empty-state-desc">No students are enrolled in this class.</p>
        <a href="/sms/students/new?classId=<%= klass.ClassID %>" class="btn-primary btn-sm mt-3">Add a student</a>
      </div>
    </div>
  <% } else { %>
    <form method="post" action="/sms/attendance/<%= klass.ClassID %>"
          hx-post="/sms/attendance/<%= klass.ClassID %>"
          hx-target="this"
          hx-swap="outerHTML">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="date" value="<%= date %>" />

      <!-- Quick actions -->
      <div class="card mb-4">
        <div class="card-body py-3 flex flex-wrap items-center gap-2 text-sm">
          <span class="kpi-label">Quick actions:</span>
          <button type="button" class="btn-secondary btn-sm" @click="markAll('Present')">Mark all Present</button>
          <button type="button" class="btn-secondary btn-sm" @click="markAll('Late')">Mark all Late</button>
          <span class="text-muted ml-auto">
            <%= sheet.rows.length %> students
          </span>
        </div>
      </div>

      <div class="card">
        <ul class="divide-y" style="border-color: rgb(var(--color-border))">
          <% sheet.rows.forEach(function(s) { %>
            <li class="p-3 sm:p-4 flex flex-col sm:flex-row sm:items-center gap-3">
              <div class="flex items-center gap-3 flex-1 min-w-0">
                <div class="h-9 w-9 rounded-full flex items-center justify-center text-white text-sm font-semibold flex-shrink-0"
                     style="background-color: rgb(var(--color-brand))">
                  <%= (s.FirstName || '?').charAt(0) %><%= (s.LastName || '').charAt(0) %>
                </div>
                <div class="min-w-0">
                  <p class="font-medium truncate"><%= s.FirstName %> <%= s.LastName %></p>
                </div>
              </div>
              <div class="flex items-center gap-1 flex-wrap" x-data="{ v: '<%= s.Status || '' %>' }">
                <% ['Present', 'Absent', 'Late', 'Excused'].forEach(function(st) { %>
                  <label class="cursor-pointer">
                    <input type="radio" name="student_<%= s.StudentID %>" value="<%= st %>"
                           class="sr-only peer" x-model="v" />
                    <span class="px-3 py-1.5 rounded-md text-sm font-medium border transition-colors peer-checked:bg-<%= st === 'Present' ? 'emerald' : st === 'Absent' ? 'red' : st === 'Late' ? 'amber' : 'slate' %>-100 dark:peer-checked:bg-<%= st === 'Present' ? 'emerald' : st === 'Absent' ? 'red' : st === 'Late' ? 'amber' : 'slate' %>-900/40 peer-checked:text-<%= st === 'Present' ? 'emerald' : st === 'Absent' ? 'red' : st === 'Late' ? 'amber' : 'slate' %>-700 dark:peer-checked:text-<%= st === 'Present' ? 'emerald' : st === 'Absent' ? 'red' : st === 'Late' ? 'amber' : 'slate' %>-300 peer-checked:border-<%= st === 'Present' ? 'emerald' : st === 'Absent' ? 'red' : st === 'Late' ? 'amber' : 'slate' %>-400 border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800">
                      <%= st %>
                    </span>
                  </label>
                <% }) %>
              </div>
              <div class="sm:w-48">
                <input type="text" name="notes_<%= s.StudentID %>" placeholder="Notes (optional)"
                       class="input text-xs" maxlength="500"
                       value="<%= s.Notes ? s.Notes.replace(/"/g, '&quot;') : '' %>" />
              </div>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="mt-4 flex items-center justify-end gap-2">
        <a href="/sms/attendance" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">Save attendance</button>
      </div>
    </form>
  <% } %>
</div>

<script>
  function attendanceSheet() {
    return {
      markAll(status) {
        document.querySelectorAll('input[type=radio][name^=student_]').forEach(function (r) {
          if (r.value === status) r.checked = true;
        });
      }
    };
  }
</script>
