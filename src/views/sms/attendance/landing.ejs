<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-narrow">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Attendance</h1>
    <p class="text-muted text-sm">Pick a class to take attendance for. History is per-class.</p>
  </div>

  <form method="get" action="/sms/attendance" class="card">
    <div class="card-body space-y-4">
      <div class="form-field">
        <label class="label" for="classId">Class</label>
        <select id="classId" name="classId" class="select" required>
          <option value="">Select a class...</option>
          <% classes.forEach(function(c) { %>
            <option value="<%= c.ClassID %>">
              <%= c.ClassName %><% if (c.Grade) { %> (Grade <%= c.Grade %>)<% } %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-field">
        <label class="label" for="date">Date</label>
        <input id="date" name="date" type="date" value="<%= defaultDate %>" class="input" />
      </div>

      <div class="flex items-center justify-end gap-2">
        <a href="/sms/classes" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">Take attendance</button>
      </div>
    </div>
  </form>
</div>
