<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Families</h1>
      <p class="text-muted text-sm"><%= total %> famil<%= total === 1 ? 'y' : 'ies' %><% if (filters.search) { %> matching "<%= filters.search %>"<% } %></p>
    </div>
    <a href="/sms/families/new" class="btn-primary">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add family
    </a>
  </div>

  <div class="card mb-4">
    <div class="card-body py-3">
      <form method="get" action="/sms/families"
            hx-get="/sms/families/partials/table"
            hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select"
            hx-target="#families-table"
            hx-swap="innerHTML"
            hx-push-url="true"
            class="flex flex-col sm:flex-row gap-2">
        <div class="flex-1 relative">
          <input type="search" name="q" value="<%= filters.search %>" placeholder="Search by family name, parent, email, or address..." class="input pl-9" />
          <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
        </div>
        <button type="button" onclick="window.location='/sms/families'" class="btn-ghost btn-sm">Reset</button>
      </form>
    </div>
  </div>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Family</th>
          <th>Primary contact</th>
          <th>Children</th>
          <th class="text-right">Outstanding</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="families-table"
             hx-get="/sms/families/partials/table"
             hx-trigger="refresh-families from:body"
             hx-swap="innerHTML">
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, layout: false }) %>
      </tbody>
    </table>
  </div>

  <% if (total > pageSize) { %>
    <div class="mt-4 flex items-center justify-between text-sm">
      <p class="text-muted">Page <%= page %> of <%= Math.ceil(total / pageSize) %></p>
      <div class="flex gap-2">
        <% var qs = filters.search ? 'q=' + encodeURIComponent(filters.search) : ''; %>
        <% if (page > 1) { %>
          <a href="/sms/families?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/families/partials/table?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#families-table" hx-swap="innerHTML" hx-push-url="true">Previous</a>
        <% } %>
        <% if (hasMore) { %>
          <a href="/sms/families?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/families/partials/table?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#families-table" hx-swap="innerHTML" hx-push-url="true">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
