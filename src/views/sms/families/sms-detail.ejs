<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page" x-data="{ tab: 'household' }">
  <nav class="mb-4 text-sm">
    <a href="/sms/families" class="text-muted hover:underline">Families</a>
    <span class="text-muted mx-1">/</span>
    <span><%= family.FamilyName %></span>
  </nav>

  <div class="card mb-6">
    <div class="card-body flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1">
        <h1 class="text-2xl font-semibold"><%= family.FamilyName %></h1>
        <p class="text-muted text-sm mt-1">
          <%= family.PrimaryParentName %>
          <% if (family.PrimaryParentPhone) { %> &middot; <%= family.PrimaryParentPhone %><% } %>
          <% if (family.PrimaryParentEmail) { %> &middot; <%= family.PrimaryParentEmail %><% } %>
        </p>
        <% if (family.HomeAddress) { %><p class="text-muted text-sm mt-1 whitespace-pre-line"><%= family.HomeAddress %></p><% } %>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/sms/students/new?familyId=<%= family.FamilyID %>" class="btn-secondary btn-sm">Add child</a>
        <a href="/sms/families/<%= family.FamilyID %>/edit" class="btn-secondary btn-sm">Edit</a>
        <button class="btn-danger btn-sm"
                hx-delete="/sms/families/<%= family.FamilyID %>"
                hx-confirm="Remove the <%= family.FamilyName %> family? Children will not be deleted but will need a new family assigned.">
          Remove
        </button>
      </div>
    </div>
  </div>

  <div class="tabs mb-4">
    <button class="tab" :class="{ 'active': tab === 'household' }" @click="tab = 'household'">Household</button>
    <button class="tab" :class="{ 'active': tab === 'children' }" @click="tab = 'children'">Children (<%= children.length %>)</button>
    <button class="tab" :class="{ 'active': tab === 'contact' }" @click="tab = 'contact'">Contact &amp; Medical</button>
  </div>

  <div x-show="tab === 'household'">
    <div class="card">
      <div class="card-body grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="kpi-label">Primary parent</p>
          <p class="font-medium"><%= family.PrimaryParentName %></p>
          <% if (family.PrimaryParentOccupation) { %><p class="text-xs text-muted"><%= family.PrimaryParentOccupation %></p><% } %>
          <% if (family.PrimaryParentPhone) { %><p class="text-xs text-muted mt-1">📞 <%= family.PrimaryParentPhone %></p><% } %>
          <% if (family.PrimaryParentWorkPhone) { %><p class="text-xs text-muted">Work: <%= family.PrimaryParentWorkPhone %></p><% } %>
          <% if (family.PrimaryParentEmail) { %><p class="text-xs text-muted">✉ <%= family.PrimaryParentEmail %></p><% } %>
          <% if (family.PrimaryParentIdNumber) { %><p class="text-xs text-muted">ID: <%= family.PrimaryParentIdNumber %></p><% } %>
        </div>
        <div>
          <p class="kpi-label">Secondary parent</p>
          <% if (family.SecondaryParentName) { %>
            <p class="font-medium"><%= family.SecondaryParentName %></p>
            <% if (family.SecondaryParentOccupation) { %><p class="text-xs text-muted"><%= family.SecondaryParentOccupation %></p><% } %>
            <% if (family.SecondaryParentPhone) { %><p class="text-xs text-muted mt-1">📞 <%= family.SecondaryParentPhone %></p><% } %>
            <% if (family.SecondaryParentEmail) { %><p class="text-xs text-muted">✉ <%= family.SecondaryParentEmail %></p><% } %>
          <% } else { %>
            <p class="text-muted">No secondary parent on file.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div x-show="tab === 'children'">
    <% if (!children || children.length === 0) { %>
      <div class="card">
        <div class="card-body empty-state">
          <p class="empty-state-desc">No children linked to this family yet.</p>
          <a href="/sms/students/new?familyId=<%= family.FamilyID %>" class="btn-primary btn-sm mt-3">Add a child</a>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <ul class="divide-y" style="border-color: rgb(var(--color-border))">
          <% children.forEach(function(s) { %>
            <li class="p-3 flex items-center justify-between">
              <div>
                <a href="/sms/students/<%= s.StudentID %>" class="font-medium hover:underline">
                  <%= s.FirstName %> <%= s.LastName %>
                </a>
                <p class="text-xs text-muted">
                  <% if (s.ClassName) { %><%= s.ClassName %><% if (s.Grade) { %> (G<%= s.Grade %>)<% } %><% } else { %>Unassigned<% } %>
                  <% if (s.DateOfBirth) { %> &middot; DOB <%= new Date(s.DateOfBirth).toLocaleDateString('en-ZA') %><% } %>
                </p>
              </div>
              <% if (s.IsActive) { %><span class="badge-success">Active</span>
              <% } else { %><span class="badge-neutral">Inactive</span><% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>
  </div>

  <div x-show="tab === 'contact'">
    <div class="card">
      <div class="card-body grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="kpi-label">Home address</p>
          <p class="font-medium whitespace-pre-line"><%= family.HomeAddress || '—' %></p>
        </div>
        <div>
          <p class="kpi-label">Emergency contact</p>
          <% if (family.EmergencyContactName) { %>
            <p class="font-medium"><%= family.EmergencyContactName %></p>
            <% if (family.EmergencyContactPhone) { %><p class="text-xs text-muted mt-1">📞 <%= family.EmergencyContactPhone %></p><% } %>
          <% } else { %>
            <p class="text-muted">Not recorded.</p>
          <% } %>
        </div>
        <div>
          <p class="kpi-label">Family doctor</p>
          <p class="font-medium"><%= family.FamilyDoctor || '—' %></p>
        </div>
        <div>
          <p class="kpi-label">Medical aid</p>
          <% if (family.MedicalAidName) { %>
            <p class="font-medium"><%= family.MedicalAidName %></p>
            <% if (family.MedicalAidNumber) { %><p class="text-xs text-muted mt-1">No: <%= family.MedicalAidNumber %></p><% } %>
          <% } else { %>
            <p class="text-muted">Not recorded.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
