<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', {
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
    title: 'No families found',
    desc: (filters && filters.search) ? 'Try clearing your search.' : 'Add your first family to get started.',
    action: (filters && filters.search) ? null : { label: 'Add family', href: '/sms/families/new' },
    colspan: 5
  }) %>
<% } else { %>
  <% rows.forEach(function(f) { %>
    <tr id="family-row-<%= f.FamilyID %>">
      <td>
        <a href="/sms/families/<%= f.FamilyID %>" class="font-medium hover:underline">
          <%= f.FamilyName %>
        </a>
      </td>
      <td>
        <p class="text-sm"><%= f.PrimaryParentName || '—' %></p>
        <% if (f.PrimaryParentEmail) { %><p class="text-xs text-muted"><%= f.PrimaryParentEmail %></p><% } %>
        <% if (f.PrimaryParentPhone) { %><p class="text-xs text-muted"><%= f.PrimaryParentPhone %></p><% } %>
      </td>
      <td>
        <span class="badge-neutral"><%= f.StudentCount || 0 %> <%= f.StudentCount === 1 ? 'child' : 'children' %></span>
      </td>
      <td class="text-right text-money">
        <% if (Number(f.OutstandingAmount) > 0) { %>
          <span class="text-red-600 dark:text-red-400 font-medium">R <%= Number(f.OutstandingAmount).toFixed(2) %></span>
        <% } else { %>
          <span class="text-emerald-600 dark:text-emerald-400">R 0.00</span>
        <% } %>
      </td>
      <td class="text-right">
        <a href="/sms/families/<%= f.FamilyID %>" class="btn-ghost btn-sm">View</a>
        <a href="/sms/families/<%= f.FamilyID %>/edit" class="btn-ghost btn-sm">Edit</a>
      </td>
    </tr>
  <% }) %>
<% } %>
