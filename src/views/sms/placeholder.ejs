<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="card">
    <div class="card-body">
      <h1 class="text-2xl font-semibold mb-1"><%= sectionTitle %></h1>
      <p class="text-muted text-sm mb-6">This screen is being migrated to the new design system.</p>
      <div class="alert-info">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div>
          <p class="font-medium">Migration in progress</p>
          <p class="text-sm opacity-90 mb-2">The full <%= title %> experience is still available in the legacy app.</p>
          <a href="<%= legacyPath %>" class="btn-secondary btn-sm">Open legacy <%= title %></a>
        </div>
      </div>
    </div>
  </div>
</div>
