<% if (!matches || matches.length === 0) { %>
  <p class="text-xs text-muted py-1">No strong matches found. You can allocate this manually.</p>
<% } else { %>
  <p class="text-xs text-muted mb-2">Suggested matches (by amount + reference):</p>
  <ul class="space-y-1">
    <% matches.forEach(function(m) { %>
      <li class="flex items-center justify-between gap-2 text-sm">
        <div>
          <a href="/sms/invoices/<%= m.InvoiceID %>" class="font-medium hover:underline">#<%= m.InvoiceNumber %></a>
          <span class="text-muted"> &middot; <%= m.StudentName || '' %></span>
          <span class="text-muted"> &middot; R <%= Number(m.Outstanding).toFixed(2) %> outstanding</span>
        </div>
        <button class="btn-primary btn-sm"
                hx-post="/sms/payments/<%= transactionId %>/allocate"
                hx-vals='{"invoiceId": "<%= m.InvoiceID %>"}'
                hx-target="#bankline-<%= transactionId %>"
                hx-swap="outerHTML">
          Allocate R <%= Number(m.Outstanding).toFixed(2) %>
        </button>
      </li>
    <% }) %>
  </ul>
<% } %>
