<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <nav class="mb-4 text-sm">
    <a href="/sms/bank-reconciliation" class="text-muted hover:underline">Reconciliation</a>
    <span class="text-muted mx-1">/</span>
    <span><%= bankAccount ? (bankAccount.AccountName || bankAccount.AccountNumber) : 'Statements' %></span>
  </nav>

  <div class="card mb-4">
    <div class="card-body flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold mb-1">Monthly statements</h1>
        <p class="text-muted text-sm"><%= bankAccount ? (bankAccount.AccountName || bankAccount.AccountNumber) : '' %></p>
      </div>
      <form method="get" action="/sms/bank-reconciliation" class="flex items-center gap-2">
        <input type="hidden" name="bankAccountId" value="<%= bankAccount ? bankAccount.BankAccountID : '' %>" />
        <label class="text-sm text-muted">Filter</label>
        <select name="filter" class="input" onchange="this.form.submit()">
          <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All</option>
          <option value="open" <%= filter === 'open' ? 'selected' : '' %>>Open</option>
          <option value="reconciled" <%= filter === 'reconciled' ? 'selected' : '' %>>Reconciled</option>
        </select>
      </form>
    </div>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Statement</th>
            <th>Bank account</th>
            <th>Month</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!statements || !statements.length) { %>
            <tr><td colspan="5" class="text-center text-muted py-6">No statements for this filter.</td></tr>
          <% } else { %>
            <% statements.forEach(function (s) { %>
              <tr>
                <td>Bank statement <%= s.StatementNumber %></td>
                <td><%= s.AccountName || s.AccountNumber %></td>
                <td><%= s.StatementMonthName %> <%= s.StatementYear %></td>
                <td>
                  <% if (s.Status === 'Reconciled') { %>
                    <span class="badge-emerald">Reconciled</span>
                  <% } else if (s.Status === 'InProgress') { %>
                    <span class="badge-amber">In progress</span>
                  <% } else { %>
                    <span class="badge-slate">Open</span>
                  <% } %>
                </td>
                <td class="text-right">
                  <a href="/sms/bank-reconciliation/<%= s.BankReconciliationStatementId %>" class="btn-secondary btn-sm">Open</a>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
