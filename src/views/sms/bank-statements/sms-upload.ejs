<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-narrow">
  <nav class="mb-4 text-sm">
    <a href="/sms/bank-statements" class="text-muted hover:underline">Bank statements</a>
    <span class="text-muted mx-1">/</span>
    <span>Upload</span>
  </nav>

  <form method="post" action="/sms/bank-statements"
        hx-post="/sms/bank-statements"
        hx-target="this"
        hx-swap="outerHTML"
        class="card">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="card-header">
      <h1 class="text-xl font-semibold">Upload statement</h1>
      <p class="text-muted text-sm mt-0.5">Paste your CSV below. Required columns: <code>Date</code>, <code>Description</code>, <code>Amount</code>. Optional: <code>Reference</code>. Dates in <code>YYYY-MM-DD</code> or <code>DD/MM/YYYY</code> format.</p>
    </div>
    <div class="card-body space-y-4">
      <div class="form-field">
        <label class="label" for="fileName">File name</label>
        <input id="fileName" name="fileName" type="text" maxlength="255" value="statement.csv" class="input" />
      </div>
      <div class="form-field">
        <label class="label label-required" for="csv">CSV content</label>
        <textarea id="csv" name="csv" rows="10" required class="textarea font-mono text-xs" placeholder="Date,Description,Amount,Reference&#10;2026-06-15,Payment from Smith,1500.00,REF123&#10;2026-06-16,Card sale,500.00,"></textarea>
        <p class="help-text">First row is the header. Amount should be a positive number.</p>
      </div>
    </div>
    <div class="card-footer flex items-center justify-end gap-2">
      <a href="/sms/bank-statements" class="btn-ghost">Cancel</a>
      <button type="submit" class="btn-primary">Import</button>
    </div>
  </form>
</div>
