<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Bank statements</h1>
      <p class="text-muted text-sm"><%= total %> statement<%= total === 1 ? '' : 's' %> uploaded</p>
    </div>
    <a href="/sms/bank-statements/new" class="btn-primary">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
      Upload statement
    </a>
  </div>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>File</th>
          <th>Uploaded</th>
          <th class="text-right">Lines</th>
          <th class="text-right">Total</th>
          <th class="text-right">Unmatched</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!rows || rows.length === 0) { %>
          <%- include('../../partials/empty/default', {
            icon: 'M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z',
            title: 'No statements uploaded',
            desc: 'Upload your first statement to reconcile payments against invoices.',
            action: { label: 'Upload statement', href: '/sms/bank-statements/new' },
            colspan: 6
          }) %>
        <% } else { %>
          <% rows.forEach(function(s) { %>
            <tr>
              <td>
                <a href="/sms/bank-statements/<%= s.BankStatementID %>" class="font-medium hover:underline"><%= s.FileName %></a>
                <% if (s.StatementDate) { %><p class="text-xs text-muted">Statement date: <%= formatDate(s.StatementDate) %></p><% } %>
              </td>
              <td class="text-sm text-muted"><%= new Date(s.CreatedDate).toLocaleString('en-ZA', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
              <td class="text-right"><%= s.LineCount %></td>
              <td class="text-right text-money"><%= formatMoney(Number(s.TotalAmount || 0)) %></td>
              <td class="text-right">
                <% if (Number(s.UnmatchedCount) > 0) { %>
                  <span class="badge-warning"><%= s.UnmatchedCount %></span>
                <% } else { %>
                  <span class="text-muted">0</span>
                <% } %>
              </td>
              <td class="text-right">
                <a href="/sms/bank-statements/<%= s.BankStatementID %>" class="btn-ghost btn-sm">Open</a>
                <button class="btn-danger btn-sm" hx-delete="/sms/bank-statements/<%= s.BankStatementID %>" hx-confirm="Delete this statement? Allocated transactions will be kept, unmatched ones removed.">Delete</button>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
