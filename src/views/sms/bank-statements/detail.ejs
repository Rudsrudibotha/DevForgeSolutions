<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <nav class="mb-4 text-sm">
    <a href="/sms/bank-statements" class="text-muted hover:underline">Bank statements</a>
    <span class="text-muted mx-1">/</span>
    <span><%= statement.FileName %></span>
  </nav>

  <div class="card mb-6">
    <div class="card-body flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold"><%= statement.FileName %></h1>
        <p class="text-muted text-sm mt-1">
          Uploaded <%= new Date(statement.CreatedDate).toLocaleString('en-ZA', { dateStyle: 'medium', timeStyle: 'short' }) %>
          <% if (statement.StatementDate) { %> &middot; Statement date <%= formatDate(statement.StatementDate) %><% } %>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <button class="btn-danger btn-sm" hx-delete="/sms/bank-statements/<%= statement.BankStatementID %>" hx-confirm="Delete this statement? Allocated transactions are kept, unmatched ones removed.">Delete</button>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="kpi-card">
      <p class="kpi-label">Lines</p>
      <p class="kpi-value"><%= lines.length %></p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Allocated</p>
      <p class="kpi-value text-emerald-600 dark:text-emerald-400"><%= lines.filter(function(l){ return l.InvoiceID; }).length %></p>
    </div>
    <div class="kpi-card">
      <p class="kpi-label">Unmatched</p>
      <p class="kpi-value <%= lines.filter(function(l){ return !l.InvoiceID; }).length > 0 ? 'text-amber-600 dark:text-amber-400' : '' %>">
        <%= lines.filter(function(l){ return !l.InvoiceID; }).length %>
      </p>
    </div>
  </div>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Description</th>
          <th>Reference</th>
          <th class="text-right">Amount</th>
          <th>Match</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!lines || lines.length === 0) { %>
          <tr><td colspan="7"><div class="empty-state"><p class="empty-state-desc">No transactions in this statement.</p></div></td></tr>
        <% } else { %>
          <% lines.forEach(function(l) { %>
            <tr id="bankline-<%= l.TransactionID %>">
              <td class="text-sm text-muted"><%= l.TransactionDate ? formatDate(l.TransactionDate) : '—' %></td>
              <td><%= l.Description %></td>
              <td class="text-muted text-sm"><%= l.Reference || '—' %></td>
              <td class="text-right text-money"><%= formatMoney(Number(l.Amount)) %></td>
              <td>
                <% if (l.InvoiceID) { %>
                  <a href="/sms/invoices/<%= l.InvoiceID %>" class="text-sm text-brand-600 dark:text-brand-300 hover:underline">#<%= l.InvoiceNumber %></a>
                  <% if (l.StudentName) { %><p class="text-xs text-muted"><%= l.StudentName %></p><% } %>
                <% } else { %>
                  <button class="text-sm text-brand-600 dark:text-brand-300 hover:underline"
                          hx-get="/sms/bank-statements/lines/<%= l.TransactionID %>/suggest"
                          hx-target="#matches-<%= l.TransactionID %>"
                          hx-swap="innerHTML">
                    Find match
                  </button>
                <% } %>
              </td>
              <td>
                <% if (l.InvoiceID) { %><span class="badge-success">Allocated</span>
                <% } else { %><span class="badge-warning">Unmatched</span><% } %>
              </td>
              <td class="text-right">
                <% if (l.InvoiceID) { %>
                  <span class="text-xs text-muted">—</span>
                <% } else { %>
                  <a href="/sms/payments/new?amount=<%= Number(l.Amount).toFixed(2) %>" class="btn-secondary btn-sm">Allocate manually</a>
                <% } %>
              </td>
            </tr>
            <% if (!l.InvoiceID) { %>
              <tr><td colspan="7" class="!p-0"><div id="matches-<%= l.TransactionID %>" class="bg-slate-50 dark:bg-slate-900/30 px-4 py-2 border-t" style="border-color: rgb(var(--color-border))"></div></td></tr>
            <% } %>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
