<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <nav class="mb-4 text-sm">
    <a href="/sms/bank-reconciliation" class="text-muted hover:underline">Reconciliation</a>
    <span class="text-muted mx-1">/</span>
    <a href="/sms/bank-reconciliation?bankAccountId=<%= statement.BankAccountId %>" class="text-muted hover:underline">Statements</a>
    <span class="text-muted mx-1">/</span>
    <span>Bank statement <%= statement.StatementNumber %> &middot; <%= statement.StatementMonthName %> <%= statement.StatementYear %></span>
  </nav>

  <div class="card mb-4">
    <div class="card-body flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold">Bank statement <%= statement.StatementNumber %></h1>
        <p class="text-muted text-sm"><%= statement.StatementMonthName %> <%= statement.StatementYear %></p>
      </div>
      <div class="flex items-center gap-2">
        <% if (statement.Status === 'Reconciled') { %>
          <span class="badge-emerald">Reconciled</span>
        <% } else { %>
          <span class="badge-amber"><%= statement.Status %></span>
        <% } %>
        <% if (statement.Status !== 'Reconciled') { %>
          <form method="post" action="/sms/bank-reconciliation/<%= statement.BankReconciliationStatementId %>/reconcile" onsubmit="return confirm('Mark this statement as reconciled? This action cannot be undone.');">
            <button class="btn-primary btn-sm" type="submit">Mark as Reconciled</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
    <!-- Transactions table -->
    <div class="lg:col-span-8 card">
      <div class="card-body p-0">
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Description / Reference</th>
                <th class="text-right">Amount</th>
                <th>Status</th>
                <th>Match</th>
                <th class="text-right"></th>
              </tr>
            </thead>
            <tbody>
              <% if (!transactions || !transactions.length) { %>
                <tr><td colspan="6" class="text-center text-muted py-6">No transactions for this month.</td></tr>
              <% } else { %>
                <% transactions.forEach(function (tx) { %>
                  <tr class="<%= selectedBankTransactionId === tx.BankTransactionId ? 'bg-brand-50' : '' %>">
                    <td><%= tx.BankEffectiveDate ? formatDate(tx.BankEffectiveDate) : '' %></td>
                    <td>
                      <p class="text-sm"><%= tx.Description || '' %></p>
                      <p class="text-xs text-muted"><%= tx.Reference || '' %></p>
                    </td>
                    <td class="text-right <%= tx.Direction === 'Credit' ? 'text-emerald-600' : 'text-rose-600' %>"><%= formatMoney(tx.Amount, statement.CurrencyCode) %></td>
                    <td><span class="badge"><%= tx.Status %></span></td>
                    <td>
                      <% if (tx.AllocatedInvoiceNumber) { %>
                        <span class="text-xs text-emerald-700">→ <%= tx.AllocatedInvoiceNumber %></span>
                      <% } else { %>
                        <span class="text-xs text-muted">unmatched</span>
                      <% } %>
                    </td>
                    <td class="text-right">
                      <a href="/sms/bank-reconciliation/<%= statement.BankReconciliationStatementId %>?tx=<%= tx.BankTransactionId %>" class="btn-secondary btn-sm">Select</a>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- AI suggestion panel (Task 72) -->
    <div class="lg:col-span-4 card">
      <div class="card-body">
        <div class="flex items-center justify-between mb-2">
          <div>
            <h2 class="text-lg font-semibold">AI suggestion</h2>
            <p class="text-muted text-xs">Read-only. You must click Apply Match manually.</p>
          </div>
          <span class="badge-brand">AI</span>
        </div>
        <% if (!selectedBankTransactionId) { %>
          <p class="text-muted text-sm">Select a transaction on the left to match it to an invoice.</p>
        <% } else { %>
          <form method="post" action="/sms/bank-reconciliation/<%= statement.BankReconciliationStatementId %>/transactions/<%= selectedBankTransactionId %>/match" class="space-y-3 mb-4">
            <div>
              <label class="label" for="invoiceId">Invoice ID</label>
              <input type="number" id="invoiceId" name="invoiceId" class="input" required min="1" placeholder="e.g. 1042" />
              <p class="help-text">Invoice must belong to this school.</p>
            </div>
            <button type="submit" class="btn-primary btn-sm w-full">Apply match</button>
          </form>
          <div id="aiSuggestionPanel" data-statement-id="<%= statement.BankReconciliationStatementId %>" data-bank-transaction-id="<%= selectedBankTransactionId %>">
            <button class="btn-secondary btn-sm" id="aiSuggestBtn">Suggest match</button>
            <div id="aiSuggestionResult" class="mt-3"></div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var panel = document.getElementById('aiSuggestionPanel');
    if (!panel) return;
    var btn = document.getElementById('aiSuggestBtn');
    var result = document.getElementById('aiSuggestionResult');
    var statementId = panel.getAttribute('data-statement-id');
    var bankTransactionId = panel.getAttribute('data-bank-transaction-id');
    btn.addEventListener('click', function () {
      btn.disabled = true;
      result.innerHTML = '<p class="text-muted text-sm">Asking AI...</p>';
      fetch('/api/ai/reconcile', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') || {}).content || ''
        },
        credentials: 'same-origin',
        body: JSON.stringify({ bankReconciliationStatementId: Number(statementId), bankTransactionId: Number(bankTransactionId) })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.error) throw new Error(data.error);
          var sug = data.suggestion || {};
          if (!sug.suggestedFamilyId) {
            result.innerHTML = '<p class="text-amber-600 text-sm">No match suggested. Please reconcile manually.</p>';
            return;
          }
          result.innerHTML = ''
            + '<p class="text-sm"><span class="font-semibold">Payer:</span> ' + (sug.suggestedPayerName || '—') + '</p>'
            + '<p class="text-sm"><span class="font-semibold">Invoice:</span> ' + (sug.suggestedInvoiceId || '—') + '</p>'
            + '<p class="text-sm"><span class="font-semibold">Confidence:</span> ' + (sug.confidence || '—') + ' (' + (sug.confidenceScore || 0) + '%)</p>'
            + '<p class="text-xs text-muted mt-1">' + (sug.reason || '') + '</p>'
            + '<div class="mt-2 flex gap-2">'
            + '  <button class="btn-primary btn-sm" id="aiApplyBtn">Apply Match</button>'
            + '  <button class="btn-secondary btn-sm" id="aiRejectBtn">Reject</button>'
            + '</div>';
          document.getElementById('aiApplyBtn').addEventListener('click', function () {
            var invoiceField = document.getElementById('invoiceId');
            if (invoiceField && sug.suggestedInvoiceId) {
              invoiceField.value = sug.suggestedInvoiceId;
              invoiceField.focus();
            } else {
              alert('Enter the invoice ID above and click Apply match.');
            }
          });
          document.getElementById('aiRejectBtn').addEventListener('click', function () {
            result.innerHTML = '<p class="text-muted text-sm">Suggestion rejected.</p>';
          });
        })
        .catch(function (err) {
          result.innerHTML = '<p class="text-rose-600 text-sm">AI unavailable: ' + err.message + '</p>';
        })
        .finally(function () { btn.disabled = false; });
    });
  })();
</script>
