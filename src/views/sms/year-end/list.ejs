<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Year-end financial closing</h1>
      <p class="text-muted text-sm">Close the financial year and carry forward balances.</p>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Status</th>
              <th>Opened at</th>
              <th>Closed at</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(list || []).length) { %>
              <tr><td colspan="5" class="text-center text-muted py-6">No year-end closures yet.</td></tr>
            <% } else { %>
              <% list.forEach(function (y) { %>
                <tr>
                  <td><%= y.Year || y.year %></td>
                  <td><span class="badge <%= y.Status === 'Closed' ? 'badge-emerald' : 'badge-amber' %>"><%= y.Status || 'Open' %></span></td>
                  <td><%= y.OpenedAt ? new Date(y.OpenedAt).toLocaleDateString('en-ZA') : '-' %></td>
                  <td><%= y.ClosedAt ? new Date(y.ClosedAt).toLocaleDateString('en-ZA') : '-' %></td>
                  <td class="text-right">
                    <% if (y.Status === 'Open') { %>
                      <button class="btn-primary btn-sm" hx-put="/api/hr/year-end/<%= y.YearEndClosingID %>/status" hx-vals='{"status":"Closed"}'>Close year</button>
                    <% } else { %>
                      <button class="btn-secondary btn-sm" hx-put="/api/hr/year-end/<%= y.YearEndClosingID %>/status" hx-vals='{"status":"Open"}'>Reopen</button>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
