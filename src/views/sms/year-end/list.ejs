<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Year-end financial closing</h1>
      <p class="text-muted text-sm">Close the financial year and carry forward balances.</p>
    </div>
  </div>

  <form method="post" action="/sms/year-end"
        hx-post="/sms/year-end"
        hx-target="this"
        hx-swap="outerHTML"
        class="card mb-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="card-body">
      <% if (errors && errors._form) { %>
        <div class="alert alert-error mb-3"><%= errors._form %></div>
      <% } %>
      <div class="grid grid-cols-1 sm:grid-cols-[200px_1fr_auto] gap-3 items-end">
        <div class="form-field">
          <label class="label label-required" for="financialYear">Financial year</label>
          <input id="financialYear" name="financialYear" type="number" min="2000" max="2100" required class="input" value="<%= form.financialYear || new Date().getFullYear() %>" />
        </div>
        <div class="text-sm text-muted pb-2">Create the closing record, then close it once rollover is complete.</div>
        <button type="submit" class="btn-primary">Create year-end</button>
      </div>
    </div>
  </form>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Year</th>
              <th>Status</th>
              <th>Opened at</th>
              <th>Closed at</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(list || []).length) { %>
              <tr><td colspan="5" class="text-center text-muted py-6">No year-end closures yet.</td></tr>
            <% } else { %>
              <% list.forEach(function (y) { %>
                <tr>
                  <td><%= y.Year || y.year %></td>
                  <td><span class="badge <%= y.Status === 'Closed' ? 'badge-emerald' : 'badge-amber' %>"><%= y.Status || 'Open' %></span></td>
                  <td><%= y.OpenedAt ? formatDate(y.OpenedAt) : '-' %></td>
                  <td><%= y.ClosedAt ? formatDate(y.ClosedAt) : '-' %></td>
                  <td class="text-right">
                    <% if (y.Status === 'Open') { %>
                      <button class="btn-primary btn-sm" hx-post="/sms/year-end/<%= y.YearEndClosingID %>/status" hx-swap="none" hx-on::after-request="if(event.detail.successful) location.reload()" hx-vals='{"status":"Closed"}'>Close year</button>
                    <% } else { %>
                      <button class="btn-secondary btn-sm" hx-post="/sms/year-end/<%= y.YearEndClosingID %>/status" hx-swap="none" hx-on::after-request="if(event.detail.successful) location.reload()" hx-vals='{"status":"Reopened for Correction","reason":"Reopened from school dashboard"}'>Reopen</button>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
