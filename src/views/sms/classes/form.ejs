<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-narrow">
  <nav class="mb-4 text-sm">
    <a href="/sms/classes" class="text-muted hover:underline">Classes</a>
    <% if (mode === 'edit') { %>
      <span class="text-muted mx-1">/</span>
      <a href="/sms/classes/<%= klass.ClassID %>" class="text-muted hover:underline"><%= klass.ClassName %></a>
      <span class="text-muted mx-1">/</span>
      <span>Edit</span>
    <% } else { %>
      <span class="text-muted mx-1">/</span>
      <span>New</span>
    <% } %>
  </nav>

  <form method="post" action="<%= mode === 'edit' ? '/sms/classes/' + klass.ClassID : '/sms/classes' %>"
        hx-post="<%= mode === 'edit' ? '/sms/classes/' + klass.ClassID : '/sms/classes' %>"
        hx-target="this"
        hx-swap="outerHTML"
        class="card">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="card-header">
      <h1 class="text-xl font-semibold"><%= mode === 'edit' ? 'Edit class' : 'Add class' %></h1>
    </div>
    <div class="card-body space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label label-required" for="className">Class name</label>
          <input id="className" name="className" type="text" required maxlength="100"
                 value="<%= klass && klass.ClassName ? klass.ClassName : '' %>"
                 class="input <%= errors.className ? 'input-error' : '' %>" />
          <% if (errors.className) { %><p class="error-text"><%= errors.className %></p><% } %>
        </div>
        <div class="form-field">
          <label class="label" for="grade">Grade</label>
          <input id="grade" name="grade" type="text" maxlength="20"
                 value="<%= klass && klass.Grade ? klass.Grade : '' %>" class="input" />
          <p class="help-text">e.g. R, 1, 2, 3...</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label" for="teacherId">Teacher</label>
          <select id="teacherId" name="teacherId" class="select">
            <option value="">Unassigned</option>
            <% teachers.forEach(function(t) { %>
              <option value="<%= t.EmployeeID %>" <%= klass && String(klass.TeacherID) === String(t.EmployeeID) ? 'selected' : '' %>>
                <%= t.Name %><% if (t.EmployeeNumber) { %> (<%= t.EmployeeNumber %>)<% } %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="form-field">
          <label class="label" for="room">Room</label>
          <input id="room" name="room" type="text" maxlength="50"
                 value="<%= klass && klass.Room ? klass.Room : '' %>" class="input" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label" for="capacity">Capacity</label>
          <input id="capacity" name="capacity" type="number" min="1" max="200"
                 value="<%= klass && klass.Capacity ? klass.Capacity : '' %>"
                 class="input <%= errors.capacity ? 'input-error' : '' %>" />
          <% if (errors.capacity) { %><p class="error-text"><%= errors.capacity %></p><% } %>
          <p class="help-text">Maximum number of students (optional).</p>
        </div>
        <div class="form-field">
          <label class="label" for="activeYear">Academic year</label>
          <input id="activeYear" name="activeYear" type="number" min="2020" max="2030" required
                 value="<%= klass && klass.ActiveYear ? klass.ActiveYear : new Date().getFullYear() %>"
                 class="input <%= errors.activeYear ? 'input-error' : '' %>" />
          <% if (errors.activeYear) { %><p class="error-text"><%= errors.activeYear %></p><% } %>
        </div>
      </div>

      <% if (mode === 'edit') { %>
        <div class="form-field">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="isActive" value="1" <%= klass && klass.IsActive ? 'checked' : '' %> class="checkbox" />
            <span class="text-sm font-medium">Active class</span>
          </label>
        </div>
      <% } else { %>
        <input type="hidden" name="isActive" value="1" />
      <% } %>
    </div>
    <div class="card-footer flex items-center justify-end gap-2">
      <a href="<%= mode === 'edit' ? '/sms/classes/' + klass.ClassID : '/sms/classes' %>" class="btn-ghost">Cancel</a>
      <button type="submit" class="btn-primary">
        <%= mode === 'edit' ? 'Save changes' : 'Add class' %>
      </button>
    </div>
  </form>
</div>
