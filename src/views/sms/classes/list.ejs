<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Classes</h1>
      <p class="text-muted text-sm"><%= total %> class<%= total === 1 ? '' : 'es' %> in <%= currentYear %><% if (filters.search || filters.grade) { %> matching filters<% } %></p>
    </div>
    <a href="/sms/classes/new" class="btn-primary">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add class
    </a>
  </div>

  <div class="card mb-4">
    <div class="card-body py-3">
      <form method="get" action="/sms/classes"
            hx-get="/sms/classes/partials/table"
            hx-trigger="keyup changed delay:250ms from:input[name=q], change from:select"
            hx-target="#classes-table"
            hx-swap="innerHTML"
            hx-push-url="true"
            class="flex flex-col sm:flex-row gap-2">
        <div class="flex-1 relative">
          <input type="search" name="q" value="<%= filters.search %>" placeholder="Search by name, room, or teacher..." class="input pl-9" />
          <svg class="absolute left-3 top-2.5 h-4 w-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/></svg>
        </div>
        <select name="grade" class="select sm:w-32">
          <option value="">All grades</option>
          <% grades.forEach(function(g) { %>
            <option value="<%= g %>" <%= filters.grade === g ? 'selected' : '' %>><%= g %></option>
          <% }) %>
        </select>
        <select name="status" class="select sm:w-32">
          <option value="active"   <%= filters.status === 'active'   ? 'selected' : '' %>>Active</option>
          <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
          <option value="all"      <%= filters.status === 'all'      ? 'selected' : '' %>>All</option>
        </select>
        <button type="button" onclick="window.location='/sms/classes'" class="btn-ghost btn-sm">Reset</button>
      </form>
    </div>
  </div>

  <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Class</th>
          <th>Grade</th>
          <th>Teacher</th>
          <th>Room</th>
          <th class="text-right">Students</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody id="classes-table"
             hx-get="/sms/classes/partials/table"
             hx-trigger="refresh-classes from:body"
             hx-swap="innerHTML">
        <%- include('partials/table', { rows, total, page, pageSize, hasMore, filters, currentYear, layout: false }) %>
      </tbody>
    </table>
  </div>

  <% if (total > pageSize) { %>
    <div class="mt-4 flex items-center justify-between text-sm">
      <p class="text-muted">Page <%= page %> of <%= Math.ceil(total / pageSize) %></p>
      <div class="flex gap-2">
        <% var qs = Object.entries(filters).filter(([k,v]) => v).map(([k,v]) => k + '=' + encodeURIComponent(v)).join('&'); %>
        <% if (page > 1) { %>
          <a href="/sms/classes?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/classes/partials/table?page=<%= page - 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#classes-table" hx-swap="innerHTML" hx-push-url="true">Previous</a>
        <% } %>
        <% if (hasMore) { %>
          <a href="/sms/classes?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>" class="btn-secondary btn-sm"
             hx-get="/sms/classes/partials/table?page=<%= page + 1 %><%= qs ? '&' + qs : '' %>"
             hx-target="#classes-table" hx-swap="innerHTML" hx-push-url="true">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
