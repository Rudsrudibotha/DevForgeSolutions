<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-narrow">
  <nav class="mb-4 text-sm">
    <a href="/sms/students" class="text-muted hover:underline">Students</a>
    <% if (mode === 'edit') { %>
      <span class="text-muted mx-1">/</span>
      <a href="/sms/students/<%= student.StudentID %>" class="text-muted hover:underline"><%= student.FirstName %> <%= student.LastName %></a>
      <span class="text-muted mx-1">/</span>
      <span>Edit</span>
    <% } else { %>
      <span class="text-muted mx-1">/</span>
      <span>New</span>
    <% } %>
  </nav>

  <div class="card">
    <div class="card-header">
      <h1 class="text-xl font-semibold"><%= mode === 'edit' ? 'Edit student' : 'Add student' %></h1>
      <p class="text-muted text-sm mt-0.5"><%= mode === 'edit' ? 'Update this student\'s details.' : 'Enrol a new student into your school.' %></p>
    </div>
    <form method="post" action="<%= mode === 'edit' ? '/sms/students/' + student.StudentID : '/sms/students' %>"
          hx-post="<%= mode === 'edit' ? '/sms/students/' + student.StudentID : '/sms/students' %>"
          hx-target="this"
          hx-swap="outerHTML"
          class="card-body space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <% if (typeof parentGate !== 'undefined' && parentGate) { %>
        <div class="alert alert-error">
          <div class="font-semibold mb-1">This family has no verified parent.</div>
          <p class="text-sm">
            A student can only be enrolled into a family that has at least one parent who has completed email and cellphone verification.
            <% if (typeof parentGate.verifiedCount !== 'undefined') { %>
              (<%= parentGate.verifiedCount %> verified)
            <% } %>
          </p>
          <a href="<%= parentGate.inviteUrl %>" class="btn-primary btn-sm mt-2 inline-block">Invite a parent</a>
        </div>
      <% } %>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label label-required" for="firstName">First name</label>
          <input id="firstName" name="firstName" type="text" required maxlength="255"
                 value="<%= student && student.FirstName ? student.FirstName : '' %>"
                 class="input <%= errors.firstName ? 'input-error' : '' %>" />
          <% if (errors.firstName) { %><p class="error-text"><%= errors.firstName %></p><% } %>
        </div>
        <div class="form-field">
          <label class="label label-required" for="lastName">Last name</label>
          <input id="lastName" name="lastName" type="text" required maxlength="255"
                 value="<%= student && student.LastName ? student.LastName : '' %>"
                 class="input <%= errors.lastName ? 'input-error' : '' %>" />
          <% if (errors.lastName) { %><p class="error-text"><%= errors.lastName %></p><% } %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label" for="dateOfBirth">Date of birth</label>
          <input id="dateOfBirth" name="dateOfBirth" type="date"
                 value="<%= student && student.DateOfBirth ? new Date(student.DateOfBirth).toISOString().slice(0,10) : '' %>"
                 class="input <%= errors.dateOfBirth ? 'input-error' : '' %>" />
          <% if (errors.dateOfBirth) { %><p class="error-text"><%= errors.dateOfBirth %></p><% } %>
        </div>
        <div class="form-field">
          <label class="label" for="classId">Class</label>
          <select id="classId" name="classId" class="select">
            <option value="">Unassigned</option>
            <% classes.forEach(function(c) { %>
              <option value="<%= c.ClassID %>" <%= student && String(student.ClassID) === String(c.ClassID) ? 'selected' : '' %>>
                <%= c.ClassName %><% if (c.Grade) { %> (Grade <%= c.Grade %>)<% } %>
              </option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label" for="enrolledDate">Date of enrolment</label>
          <input id="enrolledDate" name="enrolledDate" type="date"
                 value="<%= student && (student.EnrolledDate || student.enrolledDate) ? new Date(student.EnrolledDate || student.enrolledDate).toISOString().slice(0,10) : new Date().toISOString().slice(0,10) %>"
                 class="input <%= errors.enrolledDate ? 'input-error' : '' %>" />
          <% if (errors.enrolledDate) { %><p class="error-text"><%= errors.enrolledDate %></p><% } %>
        </div>
        <div class="form-field">
          <label class="label" for="homePhone">Home phone</label>
          <input id="homePhone" name="homePhone" type="tel" maxlength="50"
                 value="<%= student ? (student.HomePhone || student.homePhone || '') : '' %>"
                 class="input" />
        </div>
      </div>

      <div class="form-field">
        <label class="label" for="homeAddress">Home address</label>
        <textarea id="homeAddress" name="homeAddress" rows="2" maxlength="500"
                  class="textarea"><%= student ? (student.HomeAddress || student.homeAddress || '') : '' %></textarea>
      </div>

      <div class="form-field">
        <label class="label label-required" for="familyId">Family</label>
        <select id="familyId" name="familyId" required class="select <%= errors.familyId ? 'input-error' : '' %>">
          <option value="">Select a family...</option>
          <% families.forEach(function(f) { %>
            <option value="<%= f.FamilyID %>" <%= student && String(student.FamilyID) === String(f.FamilyID) ? 'selected' : '' %>>
              <%= f.FamilyName %><% if (f.PrimaryParentName) { %> &middot; <%= f.PrimaryParentName %><% } %>
            </option>
          <% }) %>
        </select>
        <p class="help-text">
          Don't see the family?
          <a href="/sms/families/new?familyName=" class="text-brand-600 dark:text-brand-300 hover:underline">Create one first</a>.
        </p>
        <% if (errors.familyId) { %><p class="error-text"><%= errors.familyId %></p><% } %>
      </div>

      <div class="form-field">
        <label class="label" for="medicalNotes">Illnesses or allergies</label>
        <textarea id="medicalNotes" name="medicalNotes" rows="3" maxlength="1000"
                  class="textarea"
                  placeholder="Allergies, conditions, medication..."><%= student && student.MedicalNotes ? student.MedicalNotes : '' %></textarea>
        <p class="help-text">Only visible to school staff. Not shown on invoices or to parents. The family doctor and medical aid are captured on the family record.</p>
      </div>

      <fieldset class="space-y-4">
        <legend class="label">Emergency contacts</legend>
        <p class="help-text -mt-2">Extra people the school may call if the parents can't be reached. The family's main emergency contact is on the family record.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="form-field">
            <label class="label" for="grandmotherName">Grandmother &mdash; surname and full name</label>
            <input id="grandmotherName" name="grandmotherName" type="text" maxlength="255"
                   value="<%= student ? (student.GrandmotherName || student.grandmotherName || '') : '' %>" class="input" />
          </div>
          <div class="form-field">
            <label class="label" for="grandmotherPhone">Grandmother &mdash; home or cell phone</label>
            <input id="grandmotherPhone" name="grandmotherPhone" type="tel" maxlength="50"
                   value="<%= student ? (student.GrandmotherPhone || student.grandmotherPhone || '') : '' %>" class="input" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="form-field">
            <label class="label" for="grandfatherName">Grandfather &mdash; surname and full name</label>
            <input id="grandfatherName" name="grandfatherName" type="text" maxlength="255"
                   value="<%= student ? (student.GrandfatherName || student.grandfatherName || '') : '' %>" class="input" />
          </div>
          <div class="form-field">
            <label class="label" for="grandfatherPhone">Grandfather &mdash; home or cell phone</label>
            <input id="grandfatherPhone" name="grandfatherPhone" type="tel" maxlength="50"
                   value="<%= student ? (student.GrandfatherPhone || student.grandfatherPhone || '') : '' %>" class="input" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="form-field">
            <label class="label" for="familyFriendName">Family friend &mdash; surname and full name</label>
            <input id="familyFriendName" name="familyFriendName" type="text" maxlength="255"
                   value="<%= student ? (student.FamilyFriendName || student.familyFriendName || '') : '' %>" class="input" />
          </div>
          <div class="form-field">
            <label class="label" for="familyFriendPhone">Family friend &mdash; home or cell phone</label>
            <input id="familyFriendPhone" name="familyFriendPhone" type="tel" maxlength="50"
                   value="<%= student ? (student.FamilyFriendPhone || student.familyFriendPhone || '') : '' %>" class="input" />
          </div>
        </div>
      </fieldset>

      <div class="form-field"
           x-data="studentBillingPicker()"
           data-assigned="<%= JSON.stringify(assignedCategoryIds) %>">
        <span class="label">Billing categories</span>
        <p class="help-text">Drag a category onto the learner's list, or use Add. You can assign more than one; the first is the primary category used for invoices.</p>
        <% if (billingCategories.length === 0) { %>
          <div class="empty-state">
            <p class="empty-state-desc">
              No active billing categories yet.
              <a href="/sms/settings" class="text-brand-600 dark:text-brand-300 hover:underline">Create them in Settings</a>.
            </p>
          </div>
        <% } else { %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-1">
            <div>
              <p class="text-xs font-medium text-muted uppercase tracking-wide mb-2">Available</p>
              <div class="space-y-2">
                <% billingCategories.forEach(function(c) { %>
                  <div x-show="!isAssigned(<%= c.BillingCategoryID %>)" x-cloak
                       draggable="true"
                       @dragstart="startDrag(<%= c.BillingCategoryID %>, $event)"
                       @dragend="endDrag()"
                       class="flex items-center justify-between gap-2 rounded-lg border p-2 cursor-grab bg-white dark:bg-slate-900"
                       style="border-color: rgb(var(--color-border))">
                    <div class="min-w-0">
                      <p class="text-sm font-medium truncate"><%= c.CategoryName %></p>
                      <p class="text-xs text-muted"><%= formatMoney(c.BaseAmount) %> &middot; <%= c.Frequency %></p>
                    </div>
                    <button type="button" class="btn-ghost btn-sm shrink-0" @click="assign(<%= c.BillingCategoryID %>)">Add</button>
                  </div>
                <% }) %>
                <p class="text-xs text-muted" x-show="assignedIds.length === <%= billingCategories.length %>" x-cloak>All categories assigned.</p>
              </div>
            </div>
            <div @dragover.prevent="overDrop = true"
                 @dragleave="overDrop = false"
                 @drop.prevent="drop($event)"
                 class="rounded-lg border-2 border-dashed p-2"
                 :class="overDrop ? 'border-brand-500 bg-brand-50 dark:bg-brand-900/20' : ''"
                 style="border-color: rgb(var(--color-border))"
                 aria-label="Billing categories assigned to this learner">
              <p class="text-xs font-medium text-muted uppercase tracking-wide mb-2">Assigned to this learner</p>
              <div class="space-y-2">
                <% billingCategories.forEach(function(c) { %>
                  <div x-show="isAssigned(<%= c.BillingCategoryID %>)" x-cloak
                       class="flex items-center justify-between gap-2 rounded-lg border p-2 bg-white dark:bg-slate-900"
                       style="border-color: rgb(var(--color-border))">
                    <div class="min-w-0">
                      <p class="text-sm font-medium truncate">
                        <%= c.CategoryName %>
                        <span class="badge-brand ml-1" x-show="isPrimary(<%= c.BillingCategoryID %>)" x-cloak>Primary</span>
                      </p>
                      <p class="text-xs text-muted"><%= formatMoney(c.BaseAmount) %> &middot; <%= c.Frequency %></p>
                    </div>
                    <div class="flex items-center gap-1 shrink-0">
                      <button type="button" class="btn-ghost btn-sm" x-show="!isPrimary(<%= c.BillingCategoryID %>)" x-cloak
                              @click="makePrimary(<%= c.BillingCategoryID %>)">Make primary</button>
                      <button type="button" class="btn-ghost btn-sm text-red-600 dark:text-red-400"
                              @click="remove(<%= c.BillingCategoryID %>)" aria-label="Remove <%= c.CategoryName %>">Remove</button>
                    </div>
                  </div>
                <% }) %>
                <p class="text-xs text-muted py-4 text-center" x-show="assignedIds.length === 0" x-cloak>Drag categories here, or use Add.</p>
              </div>
              <template x-for="id in assignedIds" :key="id">
                <input type="hidden" name="billingCategoryIds" :value="id" />
              </template>
            </div>
          </div>
        <% } %>
      </div>

      <% if (mode === 'edit') { %>
        <div class="form-field">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="isActive" <%= student && student.IsActive ? 'checked' : '' %> class="checkbox" />
            <span class="text-sm font-medium">Active student</span>
          </label>
          <p class="help-text">Untick to mark as inactive (e.g. graduated, transferred). The record is preserved.</p>
        </div>
      <% } %>

      <div class="flex items-center justify-end gap-2 pt-2">
        <a href="<%= mode === 'edit' ? '/sms/students/' + student.StudentID : '/sms/students' %>" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">
          <%= mode === 'edit' ? 'Save changes' : 'Add student' %>
        </button>
      </div>
    </form>
  </div>
</div>

<script src="/student-form.js" defer></script>
