<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Financial adjustments</h1>
      <p class="text-muted text-sm">Per-student adjustments within a family: write-offs, reversals, and corrections.</p>
    </div>
    <a href="/sms/adjustments/new" class="btn-primary">New adjustment</a>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Type</th>
              <th>Student / Family</th>
              <th>Amount</th>
              <th>Reason</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(list || []).length) { %>
              <tr><td colspan="6" class="text-center text-muted py-6">No adjustments recorded.</td></tr>
            <% } else { %>
              <% list.forEach(function (a) { %>
                <tr>
                  <td><%= a.AdjustmentID || a.adjustmentId %></td>
                  <td><%= a.AdjustmentType || a.Type || '-' %></td>
                  <td><%= a.StudentName || a.FamilyName || '-' %></td>
                  <td><%= formatMoney(a.Amount, a.CurrencyCode) %></td>
                  <td><%= a.Reason || '-' %></td>
                  <td><%= a.CreatedAt ? formatDate(a.CreatedAt) : '-' %></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
