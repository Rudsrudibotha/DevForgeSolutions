<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-narrow">
  <nav class="mb-4 text-sm">
    <a href="/sms/payments" class="text-muted hover:underline">Payments</a>
    <span class="text-muted mx-1">/</span>
    <span>Record</span>
  </nav>

  <form method="post" action="/sms/payments"
        hx-post="/sms/payments"
        hx-target="this"
        hx-swap="outerHTML"
        class="card">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="card-header">
      <h1 class="text-xl font-semibold">Record payment</h1>
      <p class="text-muted text-sm mt-0.5">Allocate to an invoice or leave Unallocated for later reconciliation.</p>
    </div>
    <div class="card-body space-y-4">
      <div class="form-field">
        <label class="label" for="invoiceId">Invoice (optional)</label>
        <select id="invoiceId" name="invoiceId" class="select">
          <option value="">Unallocated (no invoice)</option>
          <% invoices.forEach(function(inv) { %>
            <option value="<%= inv.InvoiceID %>" <%= String(defaults.invoiceId) === String(inv.InvoiceID) ? 'selected' : '' %>>
              #<%= inv.InvoiceNumber %> &middot; <%= inv.StudentName %> &middot; <%= formatMoney(Number(inv.Outstanding || (inv.Amount - inv.AmountPaid))) %> outstanding
            </option>
          <% }) %>
        </select>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label label-required" for="amount">Amount (ZAR)</label>
          <input id="amount" name="amount" type="number" min="0.01" step="0.01" required
                 value="<%= defaults.amount %>" class="input" />
        </div>
        <div class="form-field">
          <label class="label" for="paymentMethod">Method</label>
          <select id="paymentMethod" name="paymentMethod" class="select">
            <% ['EFT','Cash','Card','Cheque','DebitOrder','Mobile','Other'].forEach(function(m) { %>
              <option value="<%= m %>" <%= defaults.paymentMethod === m ? 'selected' : '' %>><%= m %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="form-field">
          <label class="label" for="transactionDate">Date</label>
          <input id="transactionDate" name="transactionDate" type="date"
                 value="<%= defaults.transactionDate %>" class="input" />
        </div>
        <div class="form-field">
          <label class="label" for="payeeName">Payee name</label>
          <input id="payeeName" name="payeeName" type="text" maxlength="255"
                 value="<%= defaults.payeeName %>" class="input" />
        </div>
      </div>

      <div class="form-field">
        <label class="label" for="description">Description / reference</label>
        <input id="description" name="description" type="text" maxlength="500"
               class="input" placeholder="e.g. Bank deposit ref 12345" />
      </div>
    </div>
    <div class="card-footer flex items-center justify-end gap-2">
      <a href="/sms/payments" class="btn-ghost">Cancel</a>
      <button type="submit" class="btn-primary">Record payment</button>
    </div>
  </form>
</div>
