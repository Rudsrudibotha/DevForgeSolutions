<% if (!rows || rows.length === 0) { %>
  <%- include('../../../partials/empty/default', {
    icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z',
    title: 'No payments found',
    desc: (filters && (filters.search || filters.allocationStatus)) ? 'Try clearing your filters.' : 'Record your first payment to allocate against an invoice.',
    action: (filters && (filters.search || filters.allocationStatus)) ? null : { label: 'Record payment', href: '/sms/payments/new' },
    colspan: 8
  }) %>
<% } else { %>
  <% rows.forEach(function(p) { %>
    <tr id="payment-row-<%= p.TransactionID %>">
      <td class="font-medium"><%= p.ReceiptNumber || '—' %></td>
      <td class="text-sm text-muted"><%= p.TransactionDate ? formatDate(p.TransactionDate) : '—' %></td>
      <td><%= p.PayeeName || '—' %></td>
      <td><%
        var methodNames = { DebitOrder: 'Debit order', Mobile: 'Mobile payment', ParentInitiated: 'Parent (online)' };
      %><%= methodNames[p.PaymentMethod] || p.PaymentMethod || '—' %></td>
      <td class="text-sm">
        <% if (p.InvoiceID) { %>
          <a href="/sms/invoices/<%= p.InvoiceID %>" class="text-brand-600 dark:text-brand-300 hover:underline">#<%= p.InvoiceNumber %></a>
          <% if (p.StudentName) { %><p class="text-xs text-muted"><%= p.StudentName %><% if (p.FamilyName) { %> &middot; <%= p.FamilyName %><% } %></p><% } %>
        <% } else { %>
          <span class="text-muted">Unallocated</span>
        <% } %>
      </td>
      <td class="text-right text-money"><%= formatMoney(p.Amount) %></td>
      <td>
        <% if (p.AllocationStatus === 'Allocated') { %><span class="badge-success">Allocated</span>
        <% } else if (p.AllocationStatus === 'PendingPayment') { %><span class="badge-warning">Awaiting parent</span>
        <% } else { %><span class="badge-neutral">Unallocated</span><% } %>
      </td>
      <td class="text-right">
        <% if (p.AllocationStatus === 'Unallocated') { %>
          <button class="btn-secondary btn-sm"
                  hx-get="/sms/payments/<%= p.TransactionID %>/allocate-form"
                  hx-target="#allocate-modal-<%= p.TransactionID %>"
                  hx-swap="innerHTML">
            Allocate
          </button>
          <div id="allocate-modal-<%= p.TransactionID %>" class="mt-2 text-left"></div>
        <% } else { %>
          <span class="text-xs text-muted">—</span>
        <% } %>
      </td>
    </tr>
  <% }) %>
<% } %>
