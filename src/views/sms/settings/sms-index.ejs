<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page" x-data="{ tab: 'school' }">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Settings</h1>
    <p class="text-muted text-sm">School profile, contact, currency, and billing categories.</p>
  </div>

  <div class="tabs mb-4">
    <button class="tab" :class="{ 'active': tab === 'school' }" @click="tab = 'school'">School profile</button>
    <button class="tab" :class="{ 'active': tab === 'billing' }" @click="tab = 'billing'">Billing categories (<%= categories.length %>)</button>
  </div>

  <div x-show="tab === 'school'">
    <% if (!school) { %>
      <div class="card"><div class="card-body empty-state"><p class="empty-state-desc">No school linked to your account.</p></div></div>
    <% } else { %>
      <form method="post" action="/sms/settings/school"
            hx-post="/sms/settings/school"
            hx-target="this"
            hx-swap="outerHTML"
            class="card">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="card-body space-y-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-field">
              <label class="label label-required" for="schoolName">School name</label>
              <input id="schoolName" name="schoolName" type="text" required maxlength="255" value="<%= school.SchoolName %>" class="input" />
            </div>
            <div class="form-field">
              <label class="label" for="contactPerson">Contact person</label>
              <input id="contactPerson" name="contactPerson" type="text" maxlength="255" value="<%= school.ContactPerson || '' %>" class="input" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-field">
              <label class="label" for="contactEmail">Contact email</label>
              <input id="contactEmail" name="contactEmail" type="email" maxlength="255" value="<%= school.ContactEmail || '' %>" class="input" />
            </div>
            <div class="form-field">
              <label class="label" for="contactPhone">Contact phone</label>
              <input id="contactPhone" name="contactPhone" type="tel" maxlength="50" value="<%= school.ContactPhone || '' %>" class="input" />
            </div>
          </div>
          <div class="form-field">
            <label class="label" for="address">Address</label>
            <textarea id="address" name="address" rows="2" maxlength="500" class="textarea"><%= school.Address || '' %></textarea>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-field">
              <label class="label" for="website">Website</label>
              <input id="website" name="website" type="url" maxlength="255" value="<%= school.Website || '' %>" class="input" placeholder="https://" />
            </div>
            <div class="form-field">
              <label class="label" for="defaultMonthlyFee">Default monthly fee (ZAR)</label>
              <input id="defaultMonthlyFee" name="defaultMonthlyFee" type="number" min="0" step="0.01"
                     value="<%= school.DefaultMonthlyFee || 0 %>" class="input" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="form-field">
              <label class="label" for="currencyCode">Currency code (ISO 4217)</label>
              <input id="currencyCode" name="currencyCode" type="text" maxlength="3" value="<%= school.CurrencyCode || 'ZAR' %>" class="input" />
            </div>
            <div class="form-field">
              <label class="label" for="currencySymbol">Currency symbol</label>
              <input id="currencySymbol" name="currencySymbol" type="text" maxlength="10" value="<%= school.CurrencySymbol || 'R' %>" class="input" />
            </div>
          </div>
          <div class="form-field">
            <label class="label" for="paymentInstructions">Payment instructions (shown on invoices)</label>
            <textarea id="paymentInstructions" name="paymentInstructions" rows="3" maxlength="500" class="textarea"
                      placeholder="e.g. Bank: FNB, Account 123456, Branch 250655, Reference: invoice #"><%= school.PaymentInstructions || '' %></textarea>
          </div>
        </div>
        <div class="card-footer flex items-center justify-end gap-2">
          <button type="submit" class="btn-primary">Save changes</button>
        </div>
      </form>
    <% } %>
  </div>

  <div x-show="tab === 'billing'">
    <div class="card mb-4">
      <div class="card-header">
        <h2 class="font-semibold">Add billing category</h2>
        <p class="text-xs text-muted mt-0.5">Reusable fee templates (Tuition, Registration, Excursion, etc.).</p>
      </div>
      <form method="post" action="/sms/settings/billing-categories"
            hx-post="/sms/settings/billing-categories"
            hx-target="this"
            hx-swap="outerHTML"
            class="card-body grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-field sm:col-span-2">
          <label class="label label-required" for="newCategoryName">Category name</label>
          <input id="newCategoryName" name="categoryName" type="text" required maxlength="255" class="input" placeholder="e.g. Tuition" />
        </div>
        <div class="form-field">
          <label class="label label-required" for="newBaseAmount">Base amount (ZAR)</label>
          <input id="newBaseAmount" name="baseAmount" type="number" required min="0" step="0.01" class="input" placeholder="0.00" />
        </div>
        <div class="form-field">
          <label class="label" for="newFrequency">Frequency</label>
          <select id="newFrequency" name="frequency" class="select">
            <option value="Monthly">Monthly</option>
            <option value="Quarterly">Quarterly</option>
            <option value="Annually">Annually</option>
            <option value="One-time">One-time</option>
          </select>
        </div>
        <div class="sm:col-span-2 lg:col-span-3 form-field">
          <label class="label" for="newDescription">Description</label>
          <input id="newDescription" name="description" type="text" maxlength="500" class="input" placeholder="Optional" />
        </div>
        <div class="flex items-end">
          <button type="submit" class="btn-primary w-full">Add category</button>
        </div>
      </form>
    </div>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Category</th>
            <th>Amount</th>
            <th>Frequency</th>
            <th>Description</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (categories.length === 0) { %>
            <tr><td colspan="5">
              <div class="empty-state"><p class="empty-state-desc">No billing categories yet. Add your first one above.</p></div>
            </td></tr>
          <% } else { %>
            <% categories.forEach(function(c) { %>
              <tr>
                <td class="font-medium"><%= c.CategoryName %></td>
                <td class="text-money">R <%= Number(c.BaseAmount).toFixed(2) %></td>
                <td class="text-sm"><%= c.Frequency %></td>
                <td class="text-sm text-muted"><%= c.Description || '—' %></td>
                <td>
                  <% if (c.IsActive) { %><span class="badge-success">Active</span>
                  <% } else { %><span class="badge-neutral">Inactive</span><% } %>
                  <form method="post" action="/sms/settings/billing-categories/<%= c.BillingCategoryID %>/toggle" class="inline ml-2">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="isActive" value="<%= c.IsActive ? 'false' : 'true' %>" />
                    <button type="submit" class="btn-ghost btn-sm">
                      <%= c.IsActive ? 'Disable' : 'Enable' %>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
