<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Subscription</h1>
    <p class="text-muted text-sm">Your current plan and available upgrades.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% (plans || []).forEach(function (p) { %>
      <div class="card <%= p.IsDefault ? 'ring-2 ring-brand-500' : '' %>">
        <div class="card-body">
          <p class="text-xs uppercase tracking-wide text-muted"><%= p.PlanCode %></p>
          <h2 class="text-xl font-semibold mt-1"><%= p.PlanName %></h2>
          <p class="text-sm text-muted mt-2"><%= p.Description || '' %></p>
          <p class="text-3xl font-semibold mt-4">R<%= p.PricePerMonth || '0' %><span class="text-sm text-muted">/mo</span></p>
          <ul class="text-sm mt-4 space-y-1">
            <% (p.features || []).forEach(function (f) { %>
              <% if (f.IsEnabled) { %>
                <li class="flex items-start gap-2">
                  <span class="text-emerald-600">✓</span>
                  <span><%= f.FeatureName %></span>
                </li>
              <% } %>
            <% }); %>
          </ul>
          <% if (p.IsDefault) { %>
            <p class="text-xs text-brand-600 mt-4 font-semibold">Your current plan</p>
          <% } else { %>
            <button class="btn-secondary w-full mt-4" disabled>Contact DevForge to switch</button>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>
