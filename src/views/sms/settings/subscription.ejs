<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Subscription</h1>
    <p class="text-muted text-sm">You are on the <span class="font-medium"><%= currentPlan %></span> plan. Compare plans and available upgrades below.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <% (plans || []).forEach(function (p) { %>
      <div class="card <%= p.IsCurrent ? 'ring-2' : '' %>" <% if (p.IsCurrent) { %>style="--tw-ring-color: rgb(var(--color-brand))"<% } %>>
        <div class="card-body flex flex-col h-full">
          <div class="flex items-center justify-between">
            <p class="text-xs uppercase tracking-wide text-muted"><%= p.PlanCode %></p>
            <% if (p.IsCurrent) { %><span class="badge-brand">Current plan</span><% } %>
          </div>
          <h2 class="text-xl font-semibold mt-1"><%= p.PlanName %></h2>
          <p class="text-sm text-muted mt-2"><%= p.Description || '' %></p>
          <% if (p.PricePerMonth) { %>
            <p class="text-3xl font-semibold mt-4 text-money">R<%= p.PricePerMonth %><span class="text-sm text-muted font-normal">/mo</span></p>
          <% } else { %>
            <p class="text-3xl font-semibold mt-4">Talk to us</p>
          <% } %>
          <ul class="text-sm mt-4 space-y-1 flex-1">
            <% (p.features || []).forEach(function (f) { %>
              <li class="flex items-start gap-2 <%= f.IsEnabled ? '' : 'text-muted' %>">
                <% if (f.IsEnabled) { %>
                  <span class="text-emerald-600 dark:text-emerald-400" aria-hidden="true">&#10003;</span>
                <% } else { %>
                  <span aria-hidden="true">&ndash;</span>
                <% } %>
                <span><%= f.FeatureName %></span>
              </li>
            <% }); %>
          </ul>
          <% if (p.IsCurrent) { %>
            <p class="text-xs mt-4 font-semibold" style="color: rgb(var(--color-brand))">Your current plan</p>
          <% } else { %>
            <a href="/sms/kch" class="btn-secondary w-full mt-4">Message DevForge to switch</a>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>

  <p class="text-xs text-muted mt-6">Plan changes are processed by DevForge and take effect on your next billing cycle. Messaging packages for Standard and Pro plans can be purchased from the Kinder Care Hub screen.</p>
</div>
