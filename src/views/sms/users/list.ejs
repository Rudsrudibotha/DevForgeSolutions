<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">System users</h1>
      <p class="text-muted text-sm">Staff who can sign in to this school.</p>
    </div>
    <button class="btn-primary" hx-get="/sms/users/new" hx-target="#newUserDialog" hx-swap="innerHTML">+ Add system user</button>
  </div>

  <div id="newUserDialog"></div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!(users || []).length) { %>
              <tr><td colspan="5" class="text-center text-muted py-6">No system users yet.</td></tr>
            <% } else { %>
              <% users.forEach(function (u) { %>
                <tr>
                  <td><%= u.Username %></td>
                  <td><%= u.Email %></td>
                  <td><%= u.Role %></td>
                  <td><span class="badge <%= u.IsActive ? 'badge-emerald' : 'badge-rose' %>"><%= u.IsActive ? 'Active' : 'Inactive' %></span></td>
                  <td class="text-right">
                    <% if (u.IsActive) { %>
                      <button class="btn-secondary btn-sm" hx-put="/api/users/school-users/<%= u.UserID %>/deactivate">Deactivate</button>
                    <% } else { %>
                      <button class="btn-primary btn-sm" hx-put="/api/users/school-users/<%= u.UserID %>/activate">Activate</button>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
