<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="card">
    <div class="card-body">
      <h1 class="text-2xl font-semibold mb-1">School dashboard</h1>
      <p class="text-muted text-sm mb-6">A quick snapshot for <%= currentSchool ? currentSchool.SchoolName : 'your school' %>.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="kpi-card">
          <p class="kpi-label">Students</p>
          <p class="kpi-value">—</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-label">Staff</p>
          <p class="kpi-value">—</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-label">Outstanding</p>
          <p class="kpi-value">—</p>
        </div>
        <div class="kpi-card">
          <p class="kpi-label">Today attendance</p>
          <p class="kpi-value">—</p>
        </div>
      </div>

      <div class="alert-info mt-6">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <div>
          <p class="font-medium">New School Management Dashboard shell</p>
          <p class="text-sm opacity-90">Detailed screens (Students, Invoices, Payments, Bank reconciliation) are being migrated to the new design. The legacy app at <code class="px-1 rounded bg-white/40 dark:bg-black/30">/sms/*</code> continues to work.</p>
        </div>
      </div>
    </div>
  </div>
</div>
