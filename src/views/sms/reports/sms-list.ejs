<% layout = 'layouts/app' %>
<% sidebar = 'school' %>

<div class="container-page">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Reports</h1>
    <p class="text-muted text-sm">Pre-built reports. Run, view, or export to CSV.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% reports.forEach(function(r) { %>
      <a href="/sms/reports/<%= r.id %>" class="card p-5 hover:shadow-elev2 transition-shadow">
        <h2 class="font-semibold"><%= r.label %></h2>
        <p class="text-sm text-muted mt-1"><%= r.description %></p>
        <p class="text-xs text-brand-600 dark:text-brand-300 mt-3">Run report &rarr;</p>
      </a>
    <% }) %>
  </div>
</div>
