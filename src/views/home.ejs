<% layout = 'layouts/app' %>
<% hideChrome = true %>

<div class="min-h-screen bg-mesh">
  <header class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img src="/assets/kinder-care-hub-logo.png" alt="" class="h-9 w-9 rounded-md" />
      <span class="font-semibold text-lg">Kinder Care Hub</span>
    </a>
    <nav class="flex items-center gap-2">
      <a href="#features" class="btn-ghost btn-sm hidden sm:inline-flex">Features</a>
      <a href="#pricing" class="btn-ghost btn-sm hidden sm:inline-flex">Pricing</a>
      <a href="/login" class="btn-secondary btn-sm">Sign in</a>
      <a href="/school-register" class="btn-primary btn-sm">Get started</a>
    </nav>
  </header>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
    <span class="badge-brand mb-4">For preschools and early learning centres</span>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight max-w-4xl mx-auto">
      The school finance &amp; management platform that just <span class="text-brand-600 dark:text-brand-300">works</span>.
    </h1>
    <p class="mt-6 text-lg text-muted max-w-2xl mx-auto">
      Invoices, payments, parents, staff and reporting — in one place, secure by default, beautiful on every device.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/school-register" class="btn-primary btn-lg">Start a free trial</a>
      <a href="/login" class="btn-secondary btn-lg">Sign in to your school</a>
    </div>
  </section>

  <section id="features" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold">One platform, three portals</h2>
      <p class="text-muted mt-2">Built for schools, their staff, and the parents they serve.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="card p-6">
        <div class="h-10 w-10 rounded-md bg-brand-100 dark:bg-brand-900/40 flex items-center justify-center mb-3">
          <svg class="h-5 w-5 text-brand-600 dark:text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <h3 class="font-semibold">School Management</h3>
        <p class="text-sm text-muted mt-1">Manage students, staff, classes, attendance, invoices and reports. Your data stays yours.</p>
      </div>
      <div class="card p-6">
        <div class="h-10 w-10 rounded-md bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center mb-3">
          <svg class="h-5 w-5 text-emerald-600 dark:text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-semibold">Parent Portal</h3>
        <p class="text-sm text-muted mt-1">Parents see every child, every school, every invoice, on any device. Pay in two taps.</p>
      </div>
      <div class="card p-6">
        <div class="h-10 w-10 rounded-md bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center mb-3">
          <svg class="h-5 w-5 text-amber-600 dark:text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h3 class="font-semibold">DevForge Admin</h3>
        <p class="text-sm text-muted mt-1">Run the business. Watch payments, manage schools, audit everything, ship features faster.</p>
      </div>
    </div>
  </section>

  <footer class="border-t mt-16" style="border-color: rgb(var(--color-border))">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 text-xs text-muted flex flex-col sm:flex-row gap-2 items-center justify-between">
      <p>&copy; <%= new Date().getFullYear() %> Kinder Care Hub. All rights reserved.</p>
      <p class="flex items-center gap-3">
        <a href="/privacy" class="hover:underline">Privacy</a>
        <a href="/terms" class="hover:underline">Terms</a>
        <a href="/status" class="hover:underline">Status</a>
      </p>
    </div>
  </footer>
</div>
