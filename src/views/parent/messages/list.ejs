<% layout = 'layouts/app' %>
<% sidebar = 'parent' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <h1 class="text-2xl font-semibold">Messages</h1>
      <p class="text-muted text-sm">Conversations with your children's schools.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1">
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="font-semibold text-sm">Conversations</h2>
          <a href="/parent/kch" class="btn-primary btn-sm">New</a>
        </div>
        <div id="conversations-list"
             hx-get="/parent/messages/partials/list"
             hx-trigger="refresh-conversations from:body"
             hx-swap="innerHTML">
          <%- include('partials/list', { conversations, layout: false }) %>
        </div>
      </div>
    </div>
    <div class="lg:col-span-2">
      <div class="card">
        <div class="card-body empty-state">
          <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          <p class="empty-state-title">Select a conversation</p>
          <p class="empty-state-desc">Pick a conversation on the left to read messages, or start a new one.</p>
        </div>
      </div>
    </div>
  </div>
</div>
