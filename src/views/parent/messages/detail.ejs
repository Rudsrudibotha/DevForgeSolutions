<% layout = 'layouts/app' %>
<% sidebar = 'parent' %>

<div class="container-page">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
    <div>
      <a href="/parent/messages" class="text-sm text-brand-600 dark:text-brand-300 hover:underline">&larr; All messages</a>
      <h1 class="text-2xl font-semibold mt-1"><%= active.Subject || '(no subject)' %></h1>
      <% if (active.SchoolName) { %><p class="text-muted text-sm">From <%= active.SchoolName %></p><% } %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1">
      <div class="card">
        <div class="card-header flex items-center justify-between">
          <h2 class="font-semibold text-sm">Conversations</h2>
          <a href="/parent/kch" class="btn-primary btn-sm">New</a>
        </div>
        <%- include('partials/list', { conversations, active, layout: false }) %>
      </div>
    </div>
    <div class="lg:col-span-2">
      <div class="card flex flex-col h-[70vh]">
        <div id="messages-list"
             hx-get="/parent/messages/<%= active.ConversationID %>/partials/messages"
             hx-trigger="refresh-messages from:body"
             hx-swap="innerHTML"
             class="flex-1 overflow-auto p-4 space-y-3">
          <%- include('partials/messages', { messages, layout: false }) %>
        </div>
        <% if (active.CanReply !== false) { %>
          <form hx-post="/parent/messages/<%= active.ConversationID %>/reply"
                hx-target="#messages-list"
                hx-swap="innerHTML"
                hx-on::after-request="document.getElementById('reply-body').value = ''"
                class="border-t p-3 flex gap-2"
                style="border-color: rgb(var(--color-border))">
            <textarea id="reply-body" name="body" rows="2" required maxlength="5000" placeholder="Type a reply..." class="textarea flex-1"></textarea>
            <button type="submit" class="btn-primary self-end">Send</button>
          </form>
        <% } else { %>
          <div class="border-t p-3 text-sm text-muted text-center" style="border-color: rgb(var(--color-border))">
            This is a notification-only thread. Replies are not accepted.
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
