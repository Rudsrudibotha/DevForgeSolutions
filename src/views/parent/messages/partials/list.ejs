<% if (!conversations || conversations.length === 0) { %>
  <div class="card-body empty-state">
    <p class="empty-state-desc">No conversations yet.</p>
  </div>
<% } else { %>
  <ul class="divide-y" style="border-color: rgb(var(--color-border))">
    <% conversations.forEach(function(c) { %>
      <li>
        <a href="/parent/messages/<%= c.ConversationID %>" class="block p-3 hover:bg-slate-50 dark:hover:bg-slate-900/40 <%= typeof active !== 'undefined' && active && active.ConversationID === c.ConversationID ? 'bg-brand-100 dark:bg-brand-900/40' : '' %>">
          <div class="flex items-start justify-between gap-2">
            <p class="font-medium text-sm truncate"><%= c.Subject || '(no subject)' %></p>
            <% if (c.UnreadCount && c.UnreadCount > 0) { %>
              <span class="badge-brand shrink-0"><%= c.UnreadCount %></span>
            <% } %>
          </div>
          <p class="text-xs text-muted truncate mt-0.5"><%= c.SchoolName || c.SchoolNameDisplay || '' %></p>
          <% if (c.LastMessageAt) { %>
            <p class="text-xs text-muted mt-1"><%= new Date(c.LastMessageAt).toLocaleString('en-ZA', { dateStyle: 'short', timeStyle: 'short' }) %></p>
          <% } %>
        </a>
      </li>
    <% }) %>
  </ul>
<% } %>
