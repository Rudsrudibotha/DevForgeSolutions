<% if (!messages || messages.length === 0) { %>
  <div class="empty-state">
    <p class="empty-state-desc">No messages in this conversation yet.</p>
  </div>
<% } else { %>
  <% messages.forEach(function(m) { %>
    <% var fromParent = m.SenderRole === 'parent' || m.SenderRole === 'Parent'; %>
    <div class="flex <%= fromParent ? 'justify-end' : 'justify-start' %>">
      <div class="max-w-[80%] rounded-lg p-3 <%= fromParent ? 'bg-brand-100 dark:bg-brand-900/40' : 'bg-slate-100 dark:bg-slate-800' %>">
        <p class="text-sm whitespace-pre-wrap"><%= m.Body || m.MessageText || '' %></p>
        <p class="text-xs text-muted mt-1">
          <%= m.SenderName || m.SenderEmail || '' %>
          <% if (m.SentAt || m.CreatedAt) { %> · <%= new Date(m.SentAt || m.CreatedAt).toLocaleString('en-ZA', { dateStyle: 'short', timeStyle: 'short' }) %><% } %>
        </p>
      </div>
    </div>
  <% }) %>
<% } %>
