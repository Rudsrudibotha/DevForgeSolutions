<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
  <% children.forEach(function(child) { %>
    <a href="/parent/child/<%= child.StudentID %>" class="child-card">
      <div class="flex items-start gap-3">
        <div class="child-avatar">
          <% if (child.PhotoUrl) { %>
            <img src="<%= child.PhotoUrl %>" alt="" class="h-12 w-12 rounded-full object-cover" />
          <% } else { %>
            <%= (child.FirstName || '?').charAt(0) %><%= (child.LastName || '').charAt(0) %>
          <% } %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-semibold truncate"><%= child.FirstName %> <%= child.LastName %></p>
          <p class="text-xs text-muted truncate"><%= child.ClassName || 'No class' %><% if (child.Grade) { %> &middot; Grade <%= child.Grade %><% } %></p>
          <p class="text-xs text-muted truncate mt-0.5">@ <%= child.SchoolName %></p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-2 pt-3 border-t" style="border-color: rgb(var(--color-border))">
        <div>
          <p class="kpi-label">Outstanding</p>
          <p class="text-sm font-semibold text-money <%= Number(child.OutstandingAmount) > 0 ? 'text-red-600 dark:text-red-400' : 'text-emerald-600 dark:text-emerald-400' %>">
            <%= formatMoney(child.OutstandingAmount || 0) %>
          </p>
        </div>
        <div>
          <p class="kpi-label">Attendance (7d)</p>
          <p class="text-sm font-semibold"><%= child.PresentLastWeek || 0 %> / 5</p>
        </div>
      </div>
    </a>
  <% }) %>
</div>
