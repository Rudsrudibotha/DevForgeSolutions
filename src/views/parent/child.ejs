<% layout = 'layouts/app' %>
<% sidebar = 'parent' %>

<div class="container-page">
  <nav class="mb-4 text-sm">
    <a href="/parent" class="text-muted hover:underline">Home</a>
    <span class="text-muted mx-1">/</span>
    <span><%= child.FirstName %> <%= child.LastName %></span>
  </nav>

  <div class="card mb-6">
    <div class="card-body flex flex-col sm:flex-row sm:items-center gap-4">
      <div class="child-avatar !h-16 !w-16 !text-2xl">
        <%= (child.FirstName || '?').charAt(0) %><%= (child.LastName || '').charAt(0) %>
      </div>
      <div class="flex-1">
        <h1 class="text-2xl font-semibold"><%= child.FirstName %> <%= child.LastName %></h1>
        <p class="text-muted text-sm">
          <%= child.ClassName || 'No class' %><% if (child.Grade) { %> &middot; Grade <%= child.Grade %><% } %>
          &middot; <%= child.SchoolName %>
        </p>
      </div>
      <div class="grid grid-cols-2 gap-4 sm:gap-6">
        <div>
          <p class="kpi-label">Outstanding</p>
          <p class="kpi-value <%= Number(child.OutstandingAmount) > 0 ? 'text-red-600 dark:text-red-400' : 'text-emerald-600 dark:text-emerald-400' %>">
            R <%= Number(child.OutstandingAmount || 0).toFixed(2) %>
          </p>
        </div>
        <div>
          <p class="kpi-label">Next due</p>
          <p class="kpi-value text-base">
            <% if (child.NextDueDate) { %><%= new Date(child.NextDueDate).toLocaleDateString('en-ZA', { day: '2-digit', month: 'short' }) %><% } else { %>—<% } %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <div x-data="{ tab: 'invoices' }">
    <div class="tabs mb-4">
      <button class="tab" :class="{ 'active': tab === 'invoices' }" @click="tab = 'invoices'">Invoices</button>
      <button class="tab" :class="{ 'active': tab === 'attendance' }" @click="tab = 'attendance'">Attendance</button>
      <button class="tab" :class="{ 'active': tab === 'consents' }" @click="tab = 'consents'">Consents</button>
    </div>

    <div x-show="tab === 'invoices'">
      <% if (!invoices || invoices.length === 0) { %>
        <%- include('../partials/empty/default', { title: 'No invoices for this child', desc: 'Invoices for this child will appear here once the school generates them.' }) %>
      <% } else { %>
        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Invoice</th>
                <th>Description</th>
                <th>Due</th>
                <th class="text-right">Amount</th>
                <th class="text-right">Paid</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% invoices.forEach(function(inv) { %>
                <tr>
                  <td class="font-medium">#<%= inv.InvoiceNumber %></td>
                  <td class="text-muted"><%= inv.Description || '—' %></td>
                  <td><%= inv.DueDate ? new Date(inv.DueDate).toLocaleDateString('en-ZA') : '—' %></td>
                  <td class="text-right text-money">R <%= Number(inv.Amount).toFixed(2) %></td>
                  <td class="text-right text-money">R <%= Number(inv.AmountPaid || 0).toFixed(2) %></td>
                  <td>
                    <% if (inv.Status === 'Paid') { %><span class="badge-success">Paid</span>
                    <% } else if (inv.Status === 'Overdue' || (inv.DueDate && new Date(inv.DueDate) < new Date() && inv.Status !== 'Paid')) { %><span class="badge-danger">Overdue</span>
                    <% } else { %><span class="badge-warning"><%= inv.Status %></span><% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div x-show="tab === 'attendance'">
      <% if (!attendance || attendance.length === 0) { %>
        <%- include('../partials/empty/default', { title: 'No attendance in the last 14 days', desc: 'The school will record attendance daily.' }) %>
      <% } else { %>
        <div class="card">
          <ul class="divide-y" style="border-color: rgb(var(--color-border))">
            <% attendance.forEach(function(a) { %>
              <li class="p-3 flex items-center justify-between text-sm">
                <div>
                  <p class="font-medium"><%= new Date(a.AttendanceDate).toLocaleDateString('en-ZA', { weekday: 'short', day: '2-digit', month: 'short' }) %></p>
                  <% if (a.Notes) { %><p class="text-xs text-muted"><%= a.Notes %></p><% } %>
                </div>
                <% if (a.Status === 'Present') { %><span class="badge-success">Present</span>
                <% } else if (a.Status === 'Absent') { %><span class="badge-danger">Absent</span>
                <% } else if (a.Status === 'Late') { %><span class="badge-warning">Late</span>
                <% } else { %><span class="badge-neutral"><%= a.Status %></span><% } %>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>
    </div>

    <div x-show="tab === 'consents'">
      <% if (!consents || consents.length === 0) { %>
        <%- include('../partials/empty/default', { title: 'No consents requested', desc: 'Schools will request your consent for outings, photos, or activities here.' }) %>
      <% } else { %>
        <div class="space-y-2">
          <% consents.forEach(function(c) { %>
            <div class="card p-4 flex items-start justify-between gap-4">
              <div>
                <p class="font-medium"><%= c.ConsentType %></p>
                <p class="text-sm text-muted"><%= c.Description || '' %></p>
                <% if (c.ExpiresOn) { %><p class="text-xs text-muted mt-1">Expires: <%= new Date(c.ExpiresOn).toLocaleDateString('en-ZA') %></p><% } %>
              </div>
              <% if (c.Status === 'Approved') { %><span class="badge-success">Approved</span>
              <% } else if (c.Status === 'Pending') { %><span class="badge-warning">Action needed</span>
              <% } else { %><span class="badge-neutral"><%= c.Status %></span><% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>
