<% layout = 'layouts/app' %>
<% sidebar = 'parent' %>

<div class="container-page">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Consent &amp; permissions</h1>
    <p class="text-muted text-sm">Permission slips from your school.</p>
  </div>

  <% if (!(list || []).length) { %>
    <div class="card">
      <div class="card-body text-center text-muted py-6">
        No outstanding permission slips.
      </div>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% list.forEach(function (c) { %>
        <div class="card">
          <div class="card-body">
            <h2 class="text-lg font-semibold"><%= c.Title %></h2>
            <p class="text-sm text-muted mt-1"><%= c.Description %></p>
            <p class="text-xs text-muted mt-2">Sent: <%= c.SentAt ? formatDate(c.SentAt) : '-' %></p>
            <p class="text-xs mt-1">Status: <span class="badge"><%= c.Status || 'Pending' %></span></p>
            <% if (c.Status === 'Pending') { %>
              <div class="mt-3 flex gap-2">
                <button class="btn-primary btn-sm" hx-post="/api/school-features/consent/<%= c.ConsentRequestID %>/respond" hx-vals='{"response":"Signed"}'>Sign</button>
                <button class="btn-secondary btn-sm" hx-post="/api/school-features/consent/<%= c.ConsentRequestID %>/respond" hx-vals='{"response":"Declined"}'>Decline</button>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
