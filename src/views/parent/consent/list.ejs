<% layout = 'layouts/app' %>
<% sidebar = 'parent' %>

<div class="container-page">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Consent &amp; permissions</h1>
    <p class="text-muted text-sm">Permission slips from your school.</p>
  </div>

  <% if (!(list || []).length) { %>
    <div class="card">
      <div class="card-body text-center text-muted py-6">
        No outstanding permission slips.
      </div>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% list.forEach(function (c) { %>
        <div class="card">
          <div class="card-body">
            <h2 class="text-lg font-semibold"><%= c.RequestTitle || c.Title || c.ConsentType || 'Permission slip' %></h2>
            <p class="text-sm text-muted mt-1"><%= c.DocumentBody || c.Notes || '' %></p>
            <p class="text-xs text-muted mt-2">Due: <%= c.DueDate ? formatDate(c.DueDate) : '-' %></p>
            <p class="text-xs mt-1">Status: <span class="badge"><%= c.Response || 'Pending' %></span></p>
            <% if ((c.Response || 'Pending') === 'Pending') { %>
              <div class="mt-3 flex gap-2">
                <button class="btn-primary btn-sm" hx-put="/api/school-features/consent/<%= c.ConsentID %>/respond" hx-swap="none" hx-on::after-request="if(event.detail.successful) location.reload()" hx-vals='{"response":"Accepted","signatureName":"<%= (user && (user.firstName || user.email)) || 'Parent' %>","signatureRelationship":"Parent"}'>Sign</button>
                <button class="btn-secondary btn-sm" hx-put="/api/school-features/consent/<%= c.ConsentID %>/respond" hx-swap="none" hx-on::after-request="if(event.detail.successful) location.reload()" hx-vals='{"response":"Declined","signatureName":"<%= (user && (user.firstName || user.email)) || 'Parent' %>","signatureRelationship":"Parent"}'>Decline</button>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>
