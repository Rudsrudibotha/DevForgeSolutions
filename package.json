{
  "name": "devforgesolutions",
  "version": "1.0.0",
  "description": "School Finance and Management System",
  "main": "src/app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/copy-vendor.js",
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "prebuild": "node scripts/copy-vendor.js && node scripts/build-css.js",
    "build": "node scripts/build-css.js",
    "build:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles/app.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/app.css -o ./public/styles/app.css --watch"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "alpinejs": "^3.13.5",
    "applicationinsights": "^2.9.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "htmx.org": "^1.9.12",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "mssql": "^12.5.4",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  },
  "keywords": [
    "school",
    "finance",
    "management",
    "saas"
  ],
  "author": "Kinder Care Hub",
  "license": "ISC"
}
