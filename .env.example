DATABASE_URL=Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=true;TrustServerCertificate=False;Connection Timeout=30;
JWT_SECRET=replace-with-a-long-random-secret
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
BASE_URL=http://localhost:3000

# Production domain example
# BASE_URL=https://devforgesolutions.com
# ALLOWED_ORIGINS=https://devforgesolutions.com,https://www.devforgesolutions.com

# AAD / Microsoft Entra ID login for the Admin dashboard only
AZURE_AD_TENANT_ID=<tenant-id>
AZURE_AD_CLIENT_ID=<client-id>
AZURE_AD_CLIENT_SECRET=<client-secret>
AZURE_AD_REDIRECT_URI=http://localhost:3000/auth/azure/callback
# AZURE_AD_REDIRECT_URI=https://devforgesolutions.com/auth/azure/callback
AZURE_AD_ADMIN_EMAILS=rudi@devforgesolutions.com,tristan@devforgesolutions.com,calvin@devforgesolutions.com

# Google login for School Management and Parent dashboards
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# GOOGLE_REDIRECT_URI=https://devforgesolutions.com/auth/google/callback

# Microsoft login for School Management and Parent dashboards
MICROSOFT_CLIENT_ID=<microsoft-client-id>
MICROSOFT_CLIENT_SECRET=<microsoft-client-secret>
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
# MICROSOFT_REDIRECT_URI=https://devforgesolutions.com/auth/microsoft/callback

# Transactional email
EMAIL_PROVIDER=postmark
EMAIL_FROM=Kinder Care Hub <no-reply@kindercarehub.example>
EMAIL_REPLY_TO=support@kindercarehub.example
REGISTRATION_NOTIFY_EMAIL=admin@kindercarehub.example
POSTMARK_SERVER_TOKEN=<postmark-server-token>
POSTMARK_MESSAGE_STREAM=outbound
# Or use Resend instead:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=<resend-api-key>
